{
  // Proxy base URLs — used when running standalone (dotnet run).
  // When launched via Aspire AppHost, these are overridden by
  // WithReference() environment variable injection.
  "ProxyUrls": {
    "Ollama":       "http://localhost:5099",
    "Foundry":      "http://localhost:5100",
    "FoundryLocal": "http://localhost:5101"
  },

  "Logging": {
    "LogLevel": {
      "Default":               "Information",
      "Microsoft.AspNetCore":  "Warning"
    }
  },

  "AllowedHosts": "*"
}
