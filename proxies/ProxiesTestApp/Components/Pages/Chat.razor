@page "/chat"
@rendermode InteractiveServer
@inject ProxyClient Client
@inject RequestHistoryService History

<PageTitle>Chat — Proxies Test App</PageTitle>

<div class="row g-3 mb-3">
    <div class="col-sm-4">
        <label class="form-label small fw-semibold">Proxy</label>
        <select class="form-select form-select-sm" @onchange="OnProxyChangedAsync">
            @foreach (var p in ProxyConfig.All)
            {
                <option value="@p.Name" selected="@(_proxy == p.Name)">@p.Label</option>
            }
        </select>
    </div>
    <div class="col-sm-4">
        <label class="form-label small fw-semibold">Model</label>
        <select class="form-select form-select-sm" @bind="_model" @bind:after="OnModelChanged">
            @foreach (var m in _modelInfos)
            {
                <option value="@m.Id">@(m.Loaded ? m.Id : $"{m.Id} (not loaded)")</option>
            }
        </select>
    </div>
    <div class="col-sm-2">
        <label class="form-label small fw-semibold">Streaming</label>
        <div class="form-check form-switch pt-1">
            <input class="form-check-input" type="checkbox" @bind="_streaming" />
            <label class="form-check-label small">@(_streaming ? "On" : "Off")</label>
        </div>
    </div>
    <div class="col-sm-2 d-flex align-items-end">
        <button class="btn btn-sm btn-outline-secondary w-100" @onclick="ClearChat">🗑 Clear</button>
    </div>
</div>

@* Model-not-loaded banner (FoundryLocalProxy only) *@
@if (_modelNotLoaded && _proxy == ProxyConfig.FoundryLocal.Name)
{
    <div class="alert alert-warning py-2 small d-flex align-items-center gap-3 mb-2" role="alert">
        <span>⚠ <strong>@_model</strong> is not loaded into memory.</span>
        @if (_loadingModel)
        {
            <div class="d-flex align-items-center gap-2">
                <div class="progress flex-grow-1" style="height:8px;min-width:120px">
                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-success"
                         style="width:@_loadProgress%"></div>
                </div>
                <span class="text-muted">@_loadMessage</span>
            </div>
        }
        else
        {
            <button class="btn btn-sm btn-success ms-auto" @onclick="LoadCurrentModelAsync">⬇ Load model</button>
        }
    </div>
}

<!-- System prompt (collapsible) -->
<div class="mb-2">
    <button class="btn btn-sm btn-link p-0 text-muted" @onclick="() => _showSystem = !_showSystem">
        ⚙ System prompt @(_showSystem ? "▲" : "▼")
    </button>
    @if (_showSystem)
    {
        <textarea class="form-control form-control-sm mt-1" rows="2"
                  placeholder="e.g. You are a pirate. Every reply must end with Arrr!"
                  @bind="_systemPrompt"></textarea>
    }
</div>

<!-- Chat window -->
<div class="chat-window mb-2" id="chat-window">
    @if (_messages.Count == 0)
    {
        <p class="text-muted small text-center m-auto">Send a message to start the conversation.</p>
    }
    @foreach (var msg in _messages)
    {
        <div class="d-flex @(msg.Role == "user" ? "justify-content-end" : "justify-content-start")">
            <div class="msg-@msg.Role">@msg.Content</div>
        </div>
    }
    @if (_typing)
    {
        <div class="d-flex justify-content-start">
            <div class="msg-assistant">
                <span class="typing-dot"></span>
                <span class="typing-dot"></span>
                <span class="typing-dot"></span>
            </div>
        </div>
    }
</div>

<!-- Input row -->
<div class="input-group">
    <textarea class="form-control" rows="2" placeholder="Type a message… (Enter to send)"
              @bind="_input" @bind:event="oninput"
              @onkeydown="OnKeyDownAsync" disabled="@_busy"></textarea>
    <button class="btn btn-primary px-4" @onclick="SendAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_input))">
        @(_busy ? "…" : "Send ▶")
    </button>
</div>
@if (_latency > 0)
{
    <p class="text-muted small mt-1">
        Last response: @_latency ms · using <code>@_model</code>
        @if (_lastTokens > 0 && _latency > 0)
        {
            <span class="ms-2 badge bg-light text-dark border">~@_lastTokens tokens · @((_lastTokens * 1000.0 / _latency).ToString("F1")) tok/s</span>
        }
    </p>
}

@code {
    [SupplyParameterFromQuery] public string? Proxy { get; set; }

    private string _proxy   = ProxyConfig.Ollama.Name;
    private string _model   = "phi-4-mini";
    private bool   _streaming = true;
    private bool   _showSystem;
    private string _systemPrompt = "";
    private string _input = "";
    private bool   _busy;
    private bool   _typing;
    private long   _latency;
    private int    _lastTokens;
    private readonly List<ChatMessage> _messages = [];
    private List<ModelInfo> _modelInfos = [new ModelInfo("phi-4-mini", true)];
    private CancellationTokenSource _cts = new();

    // Model-not-loaded / inline load state
    private bool   _modelNotLoaded;
    private bool   _loadingModel;
    private int    _loadProgress;
    private string _loadMessage = "";

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(Proxy))
            _proxy = Proxy;
        await LoadModelsAsync();
    }

    private async Task OnProxyChangedAsync(ChangeEventArgs e)
    {
        _proxy = e.Value?.ToString() ?? _proxy;
        _modelNotLoaded = false;
        await LoadModelsAsync();
    }

    private void OnModelChanged()
    {
        // Update "not loaded" banner whenever user switches model.
        var info = _modelInfos.FirstOrDefault(m => m.Id == _model);
        _modelNotLoaded = info is { Loaded: false } && _proxy == ProxyConfig.FoundryLocal.Name;
    }

    private async Task LoadModelsAsync()
    {
        var result = await Client.GetModelsAsync(_proxy);
        if (result.Ok && result.ModelInfos is { Count: > 0 })
        {
            _modelInfos = result.ModelInfos.ToList();
            _model = _modelInfos.FirstOrDefault(m => m.Loaded)?.Id
                  ?? _modelInfos[0].Id;
            OnModelChanged();
        }
    }

    private async Task LoadCurrentModelAsync()
    {
        _loadingModel = true;
        _loadProgress = 0;
        _loadMessage  = $"Starting…";
        StateHasChanged();

        await foreach (var evt in Client.LoadModelAsync(ProxyConfig.FoundryLocal.Name, _model))
        {
            _loadProgress = evt.Progress;
            _loadMessage  = evt.Message;
            await InvokeAsync(StateHasChanged);
            if (evt.Stage is "done" or "error") break;
        }

        _loadingModel   = false;
        _modelNotLoaded = false;
        _loadProgress   = 0;
        await LoadModelsAsync(); // refresh model list — model is now loaded
    }

    private async Task OnKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !_busy)
            await SendAsync();
    }

    private async Task SendAsync()
    {
        var text = _input.Trim();
        if (string.IsNullOrEmpty(text) || _busy) return;
        _input = "";
        _busy  = true;

        var contextMessages = new List<ChatMessage>();
        if (!string.IsNullOrWhiteSpace(_systemPrompt))
            contextMessages.Add(new ChatMessage("system", _systemPrompt));
        contextMessages.AddRange(_messages);
        contextMessages.Add(new ChatMessage("user", text));
        _messages.Add(new ChatMessage("user", text));

        var sw = System.Diagnostics.Stopwatch.StartNew();
        string? historyError = null;
        _lastTokens = 0;

        if (_streaming)
        {
            _typing = true;
            StateHasChanged();
            var assistantMsg = new ChatMessage("assistant", "");
            _messages.Add(assistantMsg);
            _typing = false;

            _cts = new CancellationTokenSource();
            await foreach (var token in Client.StreamChatAsync(_proxy, _model, contextMessages, _cts.Token))
            {
                assistantMsg.Content += token;
                _lastTokens++;
                await InvokeAsync(StateHasChanged);
            }
        }
        else
        {
            _typing = true;
            StateHasChanged();
            var (reply, _, error) = await Client.ChatAsync(_proxy, _model, contextMessages);
            historyError = error;
            _typing = false;
            _messages.Add(new ChatMessage("assistant", reply ?? $"⚠ {error}"));
        }

        sw.Stop();
        _latency = sw.ElapsedMilliseconds;
        _busy    = false;

        History.Add(new RequestHistoryEntry(
            Proxy:         _proxy,
            Model:         _model,
            PromptPreview: text.Length > 80 ? text[..80] + "…" : text,
            Streaming:     _streaming,
            LatencyMs:     _latency,
            TokensEstimate:_lastTokens,
            Error:         historyError,
            Timestamp:     DateTimeOffset.Now
        ));

        StateHasChanged();
    }

    private void ClearChat()
    {
        _cts.Cancel();
        _messages.Clear();
        _systemPrompt = "";
        _latency      = 0;
        _busy         = false;
    }
}
