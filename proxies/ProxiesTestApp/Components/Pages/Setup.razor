@page "/setup"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpFactory

<PageTitle>VS Code Setup — Proxies Test App</PageTitle>

<h4 class="mb-1">⚙ VS Code BYOK Setup</h4>
<p class="text-muted small mb-1">
    Ready-to-paste configuration for the VS Code
    <a href="https://code.visualstudio.com/docs/agent-customization/language-models#_add-a-custom-endpoint-model"
       target="_blank" rel="noopener">Language Models editor</a>
    (<strong>Custom Endpoint</strong> provider).
    Each proxy exposes an OpenAI-compatible
    <code>/v1/chat/completions</code> endpoint so VS Code Copilot can use it as a BYOK model.
</p>
<div class="alert alert-warning py-2 small mb-3" role="alert">
    ⚠️ The old <code>github.copilot.advanced.chatModels</code> / <code>github.copilot.chat.customOAIModels</code>
    settings are <strong>deprecated</strong> in VS Code. Use the new
    <strong>Language Models editor</strong> + <code>chatLanguageModels.json</code> format shown below.
    <a href="https://code.visualstudio.com/docs/agent-customization/language-models"
       target="_blank" rel="noopener">Official docs →</a>
</div>

<!-- Per-proxy config cards -->
<div class="row g-3 mb-4">
    @foreach (var proxy in ProxyConfig.All)
    {
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex align-items-center gap-2">
                    <span style="color:@proxy.Color; font-size:1.1rem">●</span>
                    <strong>@proxy.Label</strong>
                    <code class="ms-2 small text-muted">@proxy.DefaultUrl</code>
                    <span class="badge @(_health.TryGetValue(proxy.Name, out var h) && h ? "bg-success" : "bg-secondary") ms-auto">
                        @(_health.TryGetValue(proxy.Name, out var h2) && h2 ? "● online" : "○ offline")
                    </span>
                </div>
                <div class="card-body pb-2">
                    <p class="small text-muted mb-1">
                        Add this entry to <code>chatLanguageModels.json</code>
                        (one entry per provider in the top-level array):
                    </p>
                    <div class="d-flex gap-2 align-items-start">
                        <pre class="flex-grow-1 bg-light p-2 rounded border small mb-0"
                             style="white-space:pre-wrap;word-break:break-all">@GetConfig(proxy)</pre>
                        <button class="btn btn-sm btn-outline-primary"
                                @onclick="() => CopyTextAsync(GetConfig(proxy), proxy.Name)">📋 Copy</button>
                    </div>
                    @if (proxy == ProxyConfig.FoundryLocal)
                    {
                        <p class="small text-muted mt-2 mb-0">
                            💡 Add more loaded models to the <code>models</code> array (one entry per model alias).
                            Use the <a href="/models">🗂 Models</a> page to see what is available on this machine.
                        </p>
                    }
                    @if (proxy == ProxyConfig.Foundry)
                    {
                        <p class="small text-muted mt-2 mb-0">
                            🔑 Replace <code>YOUR_AZURE_API_KEY</code> and <code>YOUR_DEPLOYMENT_NAME</code>
                            with values from your Azure AI Foundry project.
                            See <a href="https://ai.azure.com" target="_blank" rel="noopener">ai.azure.com</a>.
                        </p>
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- Step-by-step instructions -->
<div class="card mb-4">
    <div class="card-header fw-semibold">📋 How to add a proxy to VS Code (step by step)</div>
    <div class="card-body small">
        <ol class="mb-0">
            <li class="mb-2">
                Open the <strong>Language Models editor</strong> in VS Code:<br>
                Click the model-picker dropdown in Copilot Chat → select <strong>Manage Language Models</strong> (⚙ gear icon)
                <br><em>— or —</em> press <kbd>Ctrl+Shift+P</kbd> and run <code>Chat: Manage Language Models</code>.
            </li>
            <li class="mb-2">
                Click <strong>Add Models</strong> → choose <strong>Custom Endpoint</strong>.
            </li>
            <li class="mb-2">
                Enter a <strong>group name</strong> (e.g. <em>Local Proxies</em>), a display name, and leave the API key blank
                (these proxies don't require authentication).
            </li>
            <li class="mb-2">
                Select API type: <strong>Chat Completions</strong>.
            </li>
            <li class="mb-2">
                VS Code opens <code>chatLanguageModels.json</code>. Replace or extend the generated entry
                with the snippet from the card above. <strong>Save the file.</strong>
            </li>
            <li class="mb-2">
                If the model doesn't appear immediately, press <kbd>Ctrl+Shift+P</kbd> →
                <strong>Developer: Reload Window</strong>.
            </li>
            <li>
                In Copilot Chat, open the model picker and select the new model.
            </li>
        </ol>
    </div>
</div>

<!-- Utility model section -->
<div class="card mb-4 border-info">
    <div class="card-header fw-semibold text-info-emphasis bg-info-subtle">
        🔧 Configure the Copilot utility model (optional)
    </div>
    <div class="card-body small">
        <p class="mb-2">
            VS Code uses lightweight <em>utility models</em> in the background for tasks like generating commit
            messages, rename hints, and branch names. When you're using only BYOK models (no GitHub Copilot plan),
            you must also configure these or utility features are unavailable.
        </p>
        <p class="mb-1">Add to VS Code <code>settings.json</code>:</p>
        <pre class="bg-light p-2 rounded border small mb-2" style="white-space:pre-wrap">"chat.utilityModel":      "phi-4-mini",
"chat.utilitySmallModel": "phi-4-mini"</pre>
        <p class="mb-0 text-muted">
            Each proxy also accepts the alias <code>copilot-utility-small</code> — it is remapped to the
            default model automatically, so VS Code's auto-routing works without extra config.
            <a href="https://code.visualstudio.com/docs/agent-customization/language-models#_change-the-model-for-utility-tasks"
               target="_blank" rel="noopener">Docs: utility model settings →</a>
        </p>
    </div>
</div>

<!-- Official docs links -->
<div class="card border-0 bg-light">
    <div class="card-body small">
        <strong>📚 Official documentation</strong>
        <ul class="mb-0 mt-1">
            <li>
                <a href="https://code.visualstudio.com/docs/agent-customization/language-models"
                   target="_blank" rel="noopener">
                    VS Code — AI language models &amp; BYOK overview
                </a>
                — full reference for the Language Models editor, built-in providers, and custom endpoints
            </li>
            <li>
                <a href="https://code.visualstudio.com/docs/agent-customization/language-models#_add-a-custom-endpoint-model"
                   target="_blank" rel="noopener">
                    VS Code — Add a custom endpoint model
                </a>
                — the exact steps to configure a <code>chatLanguageModels.json</code> entry
            </li>
            <li>
                <a href="https://code.visualstudio.com/docs/agent-customization/language-models#_model-configuration-reference"
                   target="_blank" rel="noopener">
                    VS Code — Model configuration reference
                </a>
                — all supported JSON properties (<code>toolCalling</code>, <code>vision</code>,
                <code>maxInputTokens</code>, etc.)
            </li>
            <li>
                <a href="https://code.visualstudio.com/docs/agent-customization/language-models#_change-the-model-for-utility-tasks"
                   target="_blank" rel="noopener">
                    VS Code — Change the model for utility tasks
                </a>
                — <code>chat.utilityModel</code> and <code>chat.utilitySmallModel</code> settings
            </li>
        </ul>
    </div>
</div>

@if (!string.IsNullOrEmpty(_copyFeedback))
{
    <div class="alert alert-success mt-3 py-2 small">✅ @_copyFeedback</div>
}

@code {
    Dictionary<string, bool> _health       = [];
    string                   _copyFeedback = "";

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(ProxyConfig.All.Select(async p =>
        {
            try
            {
                var c = HttpFactory.CreateClient(p.Name);
                c.Timeout = TimeSpan.FromSeconds(3);
                var r = await c.GetAsync("/health");
                lock (_health) _health[p.Name] = r.IsSuccessStatusCode;
            }
            catch { lock (_health) _health[p.Name] = false; }
        }));
    }

    static string GetConfig(ProxyConfig proxy)
    {
        // New chatLanguageModels.json format (Custom Endpoint provider).
        // This replaces the deprecated github.copilot.advanced.chatModels setting.
        return proxy.Name switch
        {
            "ollama-proxy" => """
                {
                  "name": "OllamaProxy (Local)",
                  "vendor": "customendpoint",
                  "models": [
                    {
                      "id": "llama3.1:8b",
                      "name": "Llama 3.1 8B (Ollama)",
                      "url": "http://localhost:5099/v1/chat/completions",
                      "toolCalling": true,
                      "maxInputTokens": 128000,
                      "maxOutputTokens": 4096
                    }
                  ]
                }
                """,

            "foundry-proxy" => """
                {
                  "name": "FoundryProxy (Azure AI)",
                  "vendor": "customendpoint",
                  "apiKey": "YOUR_AZURE_API_KEY",
                  "models": [
                    {
                      "id": "YOUR_DEPLOYMENT_NAME",
                      "name": "Azure AI Model (via FoundryProxy)",
                      "url": "http://localhost:5100/v1/chat/completions",
                      "toolCalling": true,
                      "maxInputTokens": 128000,
                      "maxOutputTokens": 4096
                    }
                  ]
                }
                """,

            "foundry-local-proxy" => """
                {
                  "name": "FoundryLocalProxy",
                  "vendor": "customendpoint",
                  "models": [
                    {
                      "id": "phi-4-mini",
                      "name": "Phi 4 Mini (Foundry Local)",
                      "url": "http://localhost:5101/v1/chat/completions",
                      "toolCalling": true,
                      "maxInputTokens": 128000,
                      "maxOutputTokens": 4096
                    },
                    {
                      "id": "copilot-utility-small",
                      "name": "Phi 4 Mini — utility (Foundry Local)",
                      "url": "http://localhost:5101/v1/chat/completions",
                      "toolCalling": false,
                      "maxInputTokens": 128000,
                      "maxOutputTokens": 512
                    }
                  ]
                }
                """,

            _ => $"{{ \"name\": \"{proxy.Label}\", \"vendor\": \"customendpoint\", \"models\": [] }}"
        };
    }

    async Task CopyTextAsync(string text, string proxyName)
    {
        _copyFeedback = $"{proxyName} config copied — paste into chatLanguageModels.json.";
        StateHasChanged();
        await Task.Delay(3000);
        _copyFeedback = "";
        StateHasChanged();
    }

    static int GetPort(string url) => new Uri(url).Port;
}
