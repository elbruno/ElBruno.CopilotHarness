@page "/models"
@rendermode InteractiveServer
@inject ProxyClient Client

<PageTitle>Model Catalog — Proxies Test App</PageTitle>

<div class="d-flex align-items-center mb-3 gap-2">
    <h4 class="mb-0">🗂 Foundry Local — Model Catalog</h4>
    <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="RefreshAsync" disabled="@_busy">↺ Refresh</button>
</div>

<p class="text-muted small mb-3">
    Live status from the <strong>Foundry Local SDK</strong>.
    <strong class="text-success">Loaded</strong> = in memory and ready.
    <strong>Cached</strong> = downloaded to disk; Load is instant.
    <strong class="text-secondary">Not cached</strong> = requires a download (one-time).
</p>

@if (!string.IsNullOrEmpty(_feedback))
{
    <div class="alert @(_feedbackOk ? "alert-success" : "alert-danger") py-2 small alert-dismissible" role="alert">
        @_feedback
        <button type="button" class="btn-close btn-sm" @onclick="() => _feedback = null"></button>
    </div>
}

@if (_loading)
{
    <p class="text-muted small">Fetching live status from FoundryLocalProxy…</p>
}
else if (_error is not null)
{
    <div class="alert alert-warning small">
        ⚠ Could not reach FoundryLocalProxy (port 5101): @_error
        <br/>Make sure the proxy is running via <code>aspire start</code>.
    </div>
}
else
{
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th style="width:140px">Status</th>
                <th>Alias</th>
                <th class="text-end">Params</th>
                <th class="text-end">Disk</th>
                <th class="text-end">RAM</th>
                <th>Description</th>
                <th style="width:200px">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in _models)
            {
                <tr>
                    <td>
                        @if (m.Loaded)
                        {
                            <span class="badge bg-success">● loaded</span>
                        }
                        else if (m.Cached)
                        {
                            <span class="badge bg-info text-dark">◎ cached</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">○ not cached</span>
                        }
                        @if (_activeAlias == m.Alias && _opProgress >= 0)
                        {
                            <div class="progress mt-1" style="height:6px">
                                <div class="progress-bar progress-bar-striped progress-bar-animated"
                                     style="width:@(_opProgress)%"></div>
                            </div>
                            <div class="text-muted" style="font-size:0.7rem">@_opMessage</div>
                        }
                    </td>
                    <td><code>@m.Alias</code></td>
                    <td class="text-end text-muted small">@m.ParamsB B</td>
                    <td class="text-end text-muted small">~@m.SizeGb GB</td>
                    <td class="text-end text-muted small">@m.RamGb GB</td>
                    <td class="small">@m.Description</td>
                    <td>
                        <div class="d-flex gap-1 flex-wrap">
                            @if (!m.Loaded)
                            {
                                <button class="btn btn-xs btn-outline-success"
                                        style="font-size:.75rem;padding:2px 6px"
                                        disabled="@(_busy)"
                                        @onclick="() => LoadAsync(m.Alias)">
                                    ⬇ Load
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-xs btn-outline-warning"
                                        style="font-size:.75rem;padding:2px 6px"
                                        disabled="@(_busy)"
                                        @onclick="() => UnloadAsync(m.Alias)">
                                    ⏏ Unload
                                </button>
                            }
                            @if (m.Cached)
                            {
                                <button class="btn btn-xs btn-outline-danger"
                                        style="font-size:.75rem;padding:2px 6px"
                                        disabled="@(_busy)"
                                        @onclick="() => DeleteAsync(m.Alias)">
                                    🗑 Delete
                                </button>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    bool    _loading  = true;
    bool    _busy;
    string? _error;
    string? _feedback;
    bool    _feedbackOk;
    List<ProxyClient.ModelStatusEntry> _models = [];

    // Load-progress state
    string? _activeAlias;
    int     _opProgress = -1;
    string  _opMessage  = "";

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    async Task RefreshAsync()
    {
        _loading = true;
        _error   = null;
        StateHasChanged();
        var result = await Client.GetModelStatusAsync(ProxyConfig.FoundryLocal.Name);
        if (result.Ok)
            _models = result.Models.ToList();
        else
            _error = result.Error;
        _loading = false;
    }

    async Task LoadAsync(string alias)
    {
        _busy = true;
        _activeAlias = alias;
        _opProgress  = 0;
        _opMessage   = $"Starting load for {alias}…";
        StateHasChanged();

        string? lastError = null;
        await foreach (var evt in Client.LoadModelAsync(ProxyConfig.FoundryLocal.Name, alias))
        {
            _opProgress = evt.Progress;
            _opMessage  = evt.Message;
            await InvokeAsync(StateHasChanged);
            if (evt.Stage == "error") { lastError = evt.Message; break; }
            if (evt.Stage == "done")  break;
        }

        _busy = false;
        _activeAlias = null;
        _opProgress  = -1;
        if (lastError is null)
        {
            _feedback   = $"✅ {alias} loaded and ready.";
            _feedbackOk = true;
        }
        else
        {
            _feedback   = $"❌ Load failed: {lastError}";
            _feedbackOk = false;
        }
        await RefreshAsync();
    }

    async Task UnloadAsync(string alias)
    {
        _busy = true;
        StateHasChanged();
        var (ok, msg) = await Client.UnloadModelAsync(ProxyConfig.FoundryLocal.Name, alias);
        _feedback   = ok ? $"✅ {msg}" : $"❌ {msg}";
        _feedbackOk = ok;
        _busy = false;
        await RefreshAsync();
    }

    async Task DeleteAsync(string alias)
    {
        _busy = true;
        StateHasChanged();
        var (ok, msg) = await Client.DeleteModelAsync(ProxyConfig.FoundryLocal.Name, alias);
        _feedback   = ok ? $"✅ {msg}" : $"❌ {msg}";
        _feedbackOk = ok;
        _busy = false;
        await RefreshAsync();
    }
}
