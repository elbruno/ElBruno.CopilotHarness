@page "/models"
@rendermode InteractiveServer
@inject ProxyClient Client
@inject IHttpClientFactory HttpFactory

<PageTitle>Model Catalog — Proxies Test App</PageTitle>

<div class="d-flex align-items-center mb-3 gap-2">
    <h4 class="mb-0">Foundry Local — Model Catalog</h4>
    <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="RefreshAsync">↺ Refresh</button>
</div>

<p class="text-muted small">
    These are the models available via the <strong>Microsoft Foundry Local SDK</strong>.
    Currently <strong>loaded</strong> models are active and respond to chat requests.
    <strong>Available</strong> models can be added by editing
    <code>proxies/FoundryLocalProxy/appsettings.json</code> →
    <code>FoundryLocal:AdditionalModels</code> and restarting the proxy.
</p>

@if (_loading)
{
    <p class="text-muted small">Loading catalog…</p>
}
else if (_error is not null)
{
    <div class="alert alert-warning small">
        ⚠ Could not fetch catalog from FoundryLocalProxy: @_error
        <br />Make sure FoundryLocalProxy is running (port 5101).
    </div>
}
else
{
    <table class="table table-sm table-hover">
        <thead class="table-light">
            <tr>
                <th>Status</th>
                <th>Alias</th>
                <th>Parameters</th>
                <th>Size</th>
                <th>RAM needed</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in _catalog)
            {
                <tr>
                    <td>
                        @if (m.Status == "loaded")
                        {
                            <span class="badge bg-success">● loaded</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">available</span>
                        }
                    </td>
                    <td><code>@m.Alias</code></td>
                    <td class="text-muted small">@m.ParamsB B</td>
                    <td class="text-muted small">~@m.SizeGb GB</td>
                    <td class="text-muted small">@m.RamGb GB</td>
                    <td class="small">@m.Description</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="card border-0 bg-light mt-3">
        <div class="card-body small">
            <strong>To load additional models</strong>, edit
            <code>proxies/FoundryLocalProxy/appsettings.json</code>:
            <pre class="mt-2 mb-0 bg-white p-2 rounded border"><code>@AppsettingsSnippet()</code></pre>
            Then restart FoundryLocalProxy (or run <code>aspire stop &amp;&amp; aspire start</code>).
            The SDK downloads the model on first load (~minutes); subsequent starts are instant.
        </div>
    </div>
}

@if (_loadedModels.Count > 0)
{
    <div class="mt-3">
        <h6>Currently loaded models</h6>
        @foreach (var m in _loadedModels)
        {
            <span class="badge bg-success me-1">@m</span>
        }
    </div>
}

@code {
    bool   _loading = true;
    string? _error;
    List<CatalogEntry> _catalog    = [];
    List<string>       _loadedModels = [];

    sealed record CatalogEntry(string Alias, double ParamsB, double SizeGb, int RamGb, string Description, string Status);

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    async Task RefreshAsync()
    {
        _loading = true;
        _error   = null;
        StateHasChanged();

        try
        {
            var client = HttpFactory.CreateClient(ProxyConfig.FoundryLocal.Name);
            var json   = await client.GetFromJsonAsync<System.Text.Json.Nodes.JsonObject>("/v1/models/catalog");
            if (json is null) throw new Exception("null response");

            _loadedModels = json["loaded"]?.AsArray()
                .Select(x => x?.GetValue<string>() ?? "")
                .Where(s => s.Length > 0)
                .ToList() ?? [];

            _catalog = json["catalog"]?.AsArray().Select(m => new CatalogEntry(
                Alias:       m?["alias"]?.GetValue<string>()       ?? "",
                ParamsB:     m?["params_b"]?.GetValue<double>()    ?? 0,
                SizeGb:      m?["size_gb"]?.GetValue<double>()     ?? 0,
                RamGb:       m?["ram_gb"]?.GetValue<int>()         ?? 0,
                Description: m?["description"]?.GetValue<string>() ?? "",
                Status:      m?["status"]?.GetValue<string>()      ?? "available"
            )).ToList() ?? [];
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    string AppsettingsSnippet() =>
        $$"""
        "FoundryLocal": {
          "DefaultModel": "phi-4-mini",
          "AdditionalModels": [ {{string.Join(", ", _catalog
              .Where(m => m.Status != "loaded")
              .Take(2)
              .Select(m => $"\"{m.Alias}\""))}} ]
        }
        """;
}
