@page "/history"
@rendermode InteractiveServer
@inject RequestHistoryService HistorySvc

<PageTitle>Request History — Proxies Test App</PageTitle>

<div class="d-flex align-items-center mb-3 gap-2">
    <h4 class="mb-0">Request History</h4>
    <span class="badge bg-secondary ms-2">@HistorySvc.Count requests</span>
    <button class="btn btn-sm btn-outline-danger ms-auto" @onclick="Clear">🗑 Clear</button>
</div>

@{
    var entries = HistorySvc.GetAll();
}

@if (entries.Count == 0)
{
    <p class="text-muted small">No requests recorded yet. Send a message on the <a href="/chat">Chat</a> or <a href="/compare">Compare</a> page.</p>
}
else
{
    <table class="table table-sm table-hover small">
        <thead class="table-light">
            <tr>
                <th>Time</th>
                <th>Proxy</th>
                <th>Model</th>
                <th>Mode</th>
                <th>Latency</th>
                <th>Tokens~</th>
                <th>Status</th>
                <th>Prompt preview</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in entries)
            {
                var proxy = ProxyConfig.All.FirstOrDefault(p => p.Name == e.Proxy);
                <tr class="@(e.Error is not null ? "table-danger" : "")">
                    <td class="text-nowrap text-muted">@e.Timestamp.ToLocalTime().ToString("HH:mm:ss")</td>
                    <td>
                        @if (proxy is not null)
                        {
                            <span style="color:@proxy.Color">●</span>
                        }
                        @e.Proxy
                    </td>
                    <td><code>@e.Model</code></td>
                    <td>@(e.Streaming ? "stream" : "batch")</td>
                    <td class="text-end">
                        @if (e.LatencyMs < 1000)
                        {
                            <span>@e.LatencyMs ms</span>
                        }
                        else
                        {
                            <span>@((e.LatencyMs / 1000.0).ToString("F1")) s</span>
                        }
                    </td>
                    <td class="text-end">
                        @if (e.TokensEstimate > 0)
                        {
                            <span title="@(e.LatencyMs > 0 ? $"{(e.TokensEstimate * 1000.0 / e.LatencyMs).ToString("F1")} tok/s" : "")">
                                @e.TokensEstimate
                                @if (e.LatencyMs > 0)
                                {
                                    <span class="text-muted"> (@((e.TokensEstimate * 1000.0 / e.LatencyMs).ToString("F1"))/s)</span>
                                }
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        @if (e.Error is not null)
                        {
                            <span class="badge bg-danger" title="@e.Error">error</span>
                        }
                        else
                        {
                            <span class="badge bg-success">ok</span>
                        }
                    </td>
                    <td class="text-muted" style="max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                        title="@e.PromptPreview">@e.PromptPreview</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    void Clear() => HistorySvc.Clear();
}
