@page "/compare"
@rendermode InteractiveServer
@inject ProxyClient Client

<PageTitle>Compare — Proxies Test App</PageTitle>

<h4 class="mb-3">⚡ Side-by-Side Comparison</h4>

<div class="row g-2 mb-3 align-items-end">
    <div class="col">
        <textarea class="form-control" rows="2"
                  placeholder="Type a prompt and send to all three proxies simultaneously…"
                  @bind="_prompt" disabled="@_busy"></textarea>
    </div>
    <div class="col-auto">
        <button class="btn btn-primary" @onclick="CompareAsync"
                disabled="@(_busy || string.IsNullOrWhiteSpace(_prompt))">
            @(_busy ? "Running…" : "▶ Send to All")
        </button>
        <button class="btn btn-outline-secondary ms-1" @onclick="Clear" disabled="@_busy">Clear</button>
    </div>
</div>

<!-- Optional system prompt -->
<div class="mb-3">
    <button class="btn btn-sm btn-link p-0 text-muted" @onclick="() => _showSys = !_showSys">
        ⚙ System prompt @(_showSys ? "▲" : "▼")
    </button>
    @if (_showSys)
    {
        <textarea class="form-control form-control-sm mt-1" rows="2"
                  placeholder="Optional system instruction applied to all three proxies"
                  @bind="_system"></textarea>
    }
</div>

<!-- Three columns -->
<div class="row g-3">
    @foreach (var p in ProxyConfig.All)
    {
        var accent = p.Name switch {
            "ollama-proxy"        => "proxy-ollama",
            "foundry-proxy"       => "proxy-foundry",
            "foundry-local-proxy" => "proxy-foundry-local",
            _ => ""
        };
        var resp    = _responses[p.Name];
        var latency = _latencies[p.Name];
        var err     = _errors[p.Name];

        <div class="col-md-4">
            <div class="card shadow-sm h-100 @accent">
                <div class="card-header d-flex justify-content-between align-items-center py-2">
                    <span class="fw-semibold small">@p.Label</span>
                    @if (latency > 0)
                    {
                        <span class="badge bg-secondary">@latency ms</span>
                    }
                    else if (_busy && _inFlight.Contains(p.Name))
                    {
                        <span class="badge bg-warning text-dark">streaming…</span>
                    }
                </div>
                <div class="card-body p-2">
                    @if (!string.IsNullOrEmpty(err))
                    {
                        <p class="text-danger small mb-0">⚠ @err</p>
                    }
                    else
                    {
                        <div class="compare-col">@resp@((_busy && _inFlight.Contains(p.Name)) ? "█" : "")</div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private string _prompt = "";
    private string _system = "";
    private bool   _showSys;
    private bool   _busy;

    private readonly Dictionary<string, string> _responses = ProxyConfig.All.ToDictionary(p => p.Name, _ => "");
    private readonly Dictionary<string, long>   _latencies = ProxyConfig.All.ToDictionary(p => p.Name, _ => 0L);
    private readonly Dictionary<string, string?> _errors   = ProxyConfig.All.ToDictionary(p => p.Name, _ => (string?)null);
    private readonly HashSet<string> _inFlight = [];
    private CancellationTokenSource _cts = new();

    private async Task CompareAsync()
    {
        if (string.IsNullOrWhiteSpace(_prompt) || _busy) return;
        _busy = true;
        _cts  = new CancellationTokenSource();

        // Reset state
        foreach (var p in ProxyConfig.All)
        {
            _responses[p.Name] = "";
            _latencies[p.Name] = 0;
            _errors[p.Name]    = null;
            _inFlight.Add(p.Name);
        }
        StateHasChanged();

        // Build shared message list
        var msgs = new List<ChatMessage>();
        if (!string.IsNullOrWhiteSpace(_system)) msgs.Add(new ChatMessage("system", _system));
        msgs.Add(new ChatMessage("user", _prompt));

        // Fire all three streams simultaneously
        var tasks = ProxyConfig.All.Select(p => StreamOneAsync(p, msgs)).ToList();
        await Task.WhenAll(tasks);

        _busy = false;
        StateHasChanged();
    }

    private async Task StreamOneAsync(ProxyConfig proxy, List<ChatMessage> msgs)
    {
        var sw = System.Diagnostics.Stopwatch.StartNew();
        try
        {
            // Discover first available model for this proxy
            var models = await Client.GetModelsAsync(proxy.Name, _cts.Token);
            var model  = models.Models.FirstOrDefault() ?? "phi-4-mini";

            await foreach (var token in Client.StreamChatAsync(proxy.Name, model, msgs, _cts.Token))
            {
                _responses[proxy.Name] += token;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _errors[proxy.Name] = ex.Message;
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            sw.Stop();
            _latencies[proxy.Name] = sw.ElapsedMilliseconds;
            _inFlight.Remove(proxy.Name);
            await InvokeAsync(StateHasChanged);
        }
    }

    private void Clear()
    {
        _cts.Cancel();
        _prompt = "";
        foreach (var p in ProxyConfig.All)
        {
            _responses[p.Name] = "";
            _latencies[p.Name] = 0;
            _errors[p.Name]    = null;
        }
        _inFlight.Clear();
        _busy = false;
    }
}
