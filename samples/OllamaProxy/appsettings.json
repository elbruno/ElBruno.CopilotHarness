{
  // ---------------------------------------------------------------------------
  // OllamaProxy — appsettings.json
  //
  // All settings here can be overridden by environment variables using the
  // standard ASP.NET Core naming convention:
  //   Ollama__BaseUrl=http://myserver:11434
  //   Ollama__DefaultModel=mistral:7b
  // ---------------------------------------------------------------------------
  "Ollama": {
    // URL of the Ollama HTTP server.
    // Default port for a local Ollama installation is 11434.
    "BaseUrl": "http://localhost:11434",

    // Model to use for ALL real inference — returned by GET /v1/models as
    // the primary model, and used as the forwarding target for every request.
    // Run `ollama pull llama3.1:8b` to download this model before starting.
    "DefaultModel": "llama3.1:8b",

    // Synthetic ID advertised for VS Code's "utility model" slot.
    //
    // WHY THIS EXISTS:
    //   Copilot's AGENT surface (the "Describe what to build" input) uses
    //   TWO model slots simultaneously:
    //     1. The MAIN model    — user's chat model (llama3.1:8b)
    //     2. The UTILITY model — a lightweight background model VS Code uses
    //                            for small tasks: chat titles, commit message
    //                            suggestions, rename hints, etc.
    //
    //   When the main model is a BYOK custom endpoint, VS Code can no longer
    //   fall back to its built-in GitHub-hosted utility models.  It needs a
    //   registered BYOK model for the utility slot.  If none is found the
    //   agent surface shows:
    //
    //     "No utility model is configured for 'copilot-utility-small'
    //      while the selected main model is BYOK."
    //
    //   By exposing this ID from GET /v1/models AND registering it in
    //   chatLanguageModels.json, users can set VS Code's chat.utilitySmallModel
    //   to this value.  The proxy then transparently rewrites it to
    //   DefaultModel before forwarding — Ollama only ever sees llama3.1:8b.
    //
    // Override with any other alias you prefer (e.g. "utility-local").
    "UtilityModelId": "copilot-utility-small"
  },

  // ---------------------------------------------------------------------------
  // Standard ASP.NET Core logging.  Set "Microsoft.AspNetCore" to "Warning"
  // to reduce noise; keep "OllamaProxy" at "Information" to see [copilot ask].
  // ---------------------------------------------------------------------------
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // AllowedHosts is an ASP.NET Core security guard.  "*" means any hostname
  // is accepted — fine for a local dev/demo proxy.
  "AllowedHosts": "*"
}
