{
  // ---------------------------------------------------------------------------
  // OllamaProxy — appsettings.json
  //
  // All settings here can be overridden by environment variables using the
  // standard ASP.NET Core naming convention:
  //   Ollama__BaseUrl=http://myserver:11434
  //   Ollama__DefaultModel=mistral:7b
  // ---------------------------------------------------------------------------
  "Ollama": {
    // URL of the Ollama HTTP server.
    // Default port for a local Ollama installation is 11434.
    "BaseUrl": "http://localhost:11434",

    // Model to use when no model is specified in the request, and the one
    // returned by GET /v1/models so VS Code BYOK knows what to offer.
    // Run `ollama pull llama3.1:8b` to download this model before starting.
    "DefaultModel": "llama3.1:8b"
  },

  // ---------------------------------------------------------------------------
  // Standard ASP.NET Core logging.  Set "Microsoft.AspNetCore" to "Warning"
  // to reduce noise; keep "OllamaProxy" at "Information" to see [copilot ask].
  // ---------------------------------------------------------------------------
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // AllowedHosts is an ASP.NET Core security guard.  "*" means any hostname
  // is accepted — fine for a local dev/demo proxy.
  "AllowedHosts": "*"
}
