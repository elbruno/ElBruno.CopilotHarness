{
  // ---------------------------------------------------------------------------
  // FoundryLocalProxy — appsettings.json
  //
  // The proxy uses the Foundry Local C# SDK (Microsoft.AI.Foundry.Local) to:
  //   1. Start the Foundry Local daemon automatically (no CLI needed)
  //   2. Download the model on first run (skips if already cached)
  //   3. Spin up an internal OpenAI-compatible REST server
  //   4. Forward VS Code BYOK requests through to that server
  //
  // All settings can be overridden by environment variables using the
  // standard ASP.NET Core naming convention (double-underscore as separator):
  //   FoundryLocal__DefaultModel=phi-4-mini
  //   FoundryLocal__AdditionalModels__0=phi-3.5-mini
  // ---------------------------------------------------------------------------
  "FoundryLocal": {
    // The model alias to load by default.
    // This model is downloaded (if not cached) and loaded at proxy startup.
    //
    // WHY phi-4-mini?
    //   - 3.8B parameters — fits in 8 GB RAM
    //   - Strong at coding and instruction-following (ideal for sub-agent tasks)
    //   - Hardware-adaptive: CPU, GPU, and NPU via Foundry Local
    //   - MIT licensed, ~2.5 GB download (cached after first run)
    //
    // Find other available aliases with: foundry model list
    // Popular alternatives:
    //   "phi-3.5-mini"         — older phi, similar size
    //   "llama-3.2-3b"        — ultra-fast, 3B parameters
    //   "mistral-7b-instruct" — strong coding, needs more RAM
    "DefaultModel": "phi-4-mini",

    // Extra model aliases to download and load alongside DefaultModel.
    // All listed models become selectable in VS Code via this proxy.
    // Example: [ "phi-3.5-mini", "llama-3.2-3b" ]
    // The Foundry Local SDK auto-selects the best hardware variant for each.
    "AdditionalModels": [],

    // Internal port for the Foundry Local SDK's REST server.
    // The SDK starts its own OpenAI-compatible HTTP server on this port;
    // the proxy (always on 5101) forwards requests to it.
    // Change this only if 55588 is already in use on your machine.
    "InternalPort": 55588,

    // Synthetic ID advertised for VS Code's "utility model" slot.
    // See Program.cs for a full explanation of why this exists.
    "UtilityModelId": "copilot-utility-small",

    // When true (default), download execution providers (GPU/NPU drivers) at
    // startup so Foundry Local can use the best available hardware accelerator.
    // Set to false to skip EP download and run on CPU only.
    "DownloadExecutionProviders": true
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      // Suppress the verbose Foundry Local SDK internal logs in the console.
      // Set to "Debug" if you need to troubleshoot SDK behaviour.
      "Microsoft.AI.Foundry": "Warning",
      // Suppress per-request HTTP client lifecycle noise (Start/Sending/Received/End).
      // Set to "Information" to see the raw forwarded request/response details.
      "System.Net.Http.HttpClient": "Warning"
    }
  },

  "AllowedHosts": "*"
}
