{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "System.Net.Http.HttpClient": "Warning",
      "Polly": "Warning"
    }
  },
  "FoundryLocal": {
    "Endpoint": "http://localhost:5101",
    "DefaultModel": "phi-4-mini"
  },
  "Routing": {
    "DefaultProfile": "small",
    "Profiles": {
      "local": {
        "Deployment": "gpt-5-mini",
        "ApiVersion": "2024-10-21",
        "Enabled": true
      },
      "small": {
        "Deployment": "gpt-5-mini",
        "ApiVersion": "2024-10-21",
        "Enabled": true
      },
      "big": {
        "Deployment": "gpt-5-mini",
        "ApiVersion": "2024-10-21",
        "Enabled": true
      }
    },
    "Rules": {
      "BigPromptCharacterThreshold": 2500,
      "BigProfile": "big",
      "StreamingProfile": "small",
      "PreferBigWhenSystemMessageExists": true,
      "PreferStreamingProfileWhenStreaming": true,
      "LocalToolCallingMaxPromptCharacters": 12000,
      "LocalRouteMaxTokens": 4096
    }
  },
  "Persistence": {
    "DatabasePath": "App_Data\\copilotharness-admin.db"
  },
  "AllowedHosts": "*"
}
