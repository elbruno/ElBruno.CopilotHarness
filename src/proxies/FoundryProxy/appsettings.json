{
  // ---------------------------------------------------------------------------
  // FoundryProxy — appsettings.json
  //
  // ⚠️  SECURITY NOTE — READ BEFORE EDITING ⚠️
  // ---------------------------------------------------------------------------
  // The three required secrets (Endpoint, ApiKey, Deployment) must NEVER be
  // committed to source control.  They belong in .NET User Secrets:
  //
  //   cd samples\FoundryProxy
  //   dotnet user-secrets set "Foundry:Endpoint"   "https://<your-resource>.openai.azure.com"
  //   dotnet user-secrets set "Foundry:ApiKey"     "<your-key>"
  //   dotnet user-secrets set "Foundry:Deployment" "gpt-4o-mini"
  //
  // On Windows, secrets are stored in:
  //   %APPDATA%\Microsoft\UserSecrets\adc0ec66-b21e-4f58-93a3-14e8049f8b55\secrets.json
  //
  // All settings here can be overridden by environment variables using the
  // standard ASP.NET Core naming convention (double-underscore as separator):
  //   Foundry__Endpoint=https://myresource.openai.azure.com
  //   Foundry__ApiKey=abc123
  //   Foundry__Deployment=gpt-4o-mini
  // ---------------------------------------------------------------------------
  "Foundry": {
    // Microsoft Foundry / Azure OpenAI resource endpoint.
    // Format: https://<resource-name>.openai.azure.com
    // AI Foundry project endpoints are also accepted (e.g. https://<hub>.api.azureml.ms/...).
    // Trailing /openai or /openai/v1 suffixes are stripped automatically.
    // SET VIA USER SECRETS — leave empty here.
    "Endpoint": "",

    // Azure OpenAI resource key (Primary or Secondary key from the Azure portal).
    // Azure uses the "api-key" HTTP header, not a Bearer token.
    // SET VIA USER SECRETS — leave empty here.
    "ApiKey": "",

    // The DEPLOYMENT NAME of the model in your Microsoft Foundry / Azure OpenAI resource.
    // This is the name you gave when you created the deployment (e.g. "gpt-4o-mini"),
    // NOT the base model name.  It appears in the Azure portal under
    // Azure OpenAI → Deployments.
    // This is the FALLBACK deployment — used for the utility slot and for any
    // requested model id that is not listed in "Deployments" below.
    // SET VIA USER SECRETS — leave empty here.
    "Deployment": "",

    // OPTIONAL allowlist of deployment names this proxy may route to.
    // When VS Code requests one of these ids, the proxy uses it AS the Azure
    // deployment name (URL path) — so selecting different models in VS Code
    // hits different Foundry deployments from ONE endpoint. Parity with the
    // Ollama sample's install-aware pass-through.
    //   "Deployments": [ "gpt-5.5", "gpt-chat-latest", "DeepSeek-V4-Flash" ]
    // Or via env: Foundry__Deployments__0=gpt-5.5  Foundry__Deployments__1=...
    // Leave EMPTY to allow ANY requested id to be used as a deployment name
    // (the utility alias always falls back to "Deployment" above).
    // These are deployment names, not secrets — safe to commit.
    "Deployments": [],

    // Azure OpenAI REST API version to use.
    // 2024-10-21 is a stable GA version; override if you need a newer preview.
    // This value is safe to commit — it is not a secret.
    "ApiVersion": "2024-10-21",

    // Synthetic ID advertised for VS Code's "utility model" slot.
    // See Program.cs for a detailed explanation of why this exists.
    // This value is safe to commit — it is not a secret.
    "UtilityModelId": "copilot-utility-small",

    // Newer Foundry models (gpt-5.x, gpt-chat-latest, o-series, o1, o3...) only
    // accept the DEFAULT temperature/top_p of 1 and return a 400
    // "unsupported_value" for anything else. VS Code Copilot sends
    // temperature: 0.1 on every call, so when true (the default) this proxy
    // strips any non-default temperature/top_p before forwarding.
    // Set to false only if you target an OLDER model that honors custom values.
    "StripUnsupportedSamplingParams": true
  },

  // ---------------------------------------------------------------------------
  // Standard ASP.NET Core logging.  Set "Microsoft.AspNetCore" to "Warning"
  // to reduce noise; keep "FoundryProxy" at "Information" to see [copilot ask].
  // ---------------------------------------------------------------------------
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // AllowedHosts is an ASP.NET Core security guard.  "*" means any hostname
  // is accepted — fine for a local dev/demo proxy.
  "AllowedHosts": "*"
}
