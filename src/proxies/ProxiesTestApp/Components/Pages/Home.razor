@page "/"
@rendermode InteractiveServer
@inject ProxyClient Client

<PageTitle>Health — Proxies Test App</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">🏠 Proxy Health Dashboard</h4>
    <div class="d-flex align-items-center gap-2">
        <span class="text-muted small">auto-refresh every 5 s</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshAll" disabled="@_busy">
            @(_busy ? "Checking…" : "↻ Refresh")
        </button>
    </div>
</div>

<div class="row g-3">
    @foreach (var proxy in ProxyConfig.All)
    {
        var result = _results.GetValueOrDefault(proxy.Name);
        var accent = proxy.Name switch {
            "ollama-proxy"       => "proxy-ollama",
            "foundry-proxy"      => "proxy-foundry",
            "foundry-local-proxy"=> "proxy-foundry-local",
            _                    => ""
        };
        <div class="col-md-4">
            <div class="card shadow-sm h-100 @accent">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="card-title mb-0 fw-semibold">@proxy.Label</h6>
                        @if (result is null)
                        {
                            <span class="badge badge-wait">…</span>
                        }
                        else if (result.Ok)
                        {
                            <span class="badge badge-ok">🟢 OK</span>
                        }
                        else
                        {
                            <span class="badge badge-err">🔴 Down</span>
                        }
                    </div>

                    @if (result is null)
                    {
                        <p class="text-muted small mb-0">Checking…</p>
                    }
                    else if (result.Ok)
                    {
                        <table class="table table-sm table-borderless mb-0 small">
                            <tr><td class="text-muted">Model</td>  <td class="fw-semibold">@result.Model</td></tr>
                            <tr><td class="text-muted">Latency</td><td>@result.LatencyMs ms</td></tr>
                            <tr><td class="text-muted">URL</td>    <td class="text-muted">@proxy.DefaultUrl</td></tr>
                        </table>
                        <a href="/chat?proxy=@proxy.Name" class="btn btn-sm btn-outline-primary mt-2">💬 Open Chat</a>
                    }
                    else
                    {
                        <p class="text-danger small mb-1">@result.Error</p>
                        <p class="text-muted small mb-0">@proxy.DefaultUrl</p>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private readonly Dictionary<string, HealthResult> _results = new();
    private bool _busy;
    private Timer? _timer;
    private CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        await RefreshAll();
        _timer = new Timer(_ => InvokeAsync(RefreshAll), null,
            TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private async Task RefreshAll()
    {
        if (_busy) return;
        _busy = true;
        StateHasChanged();

        var tasks = ProxyConfig.All.Select(async p =>
        {
            var r = await Client.GetHealthAsync(p.Name, _cts.Token);
            _results[p.Name] = r;
            await InvokeAsync(StateHasChanged);
        });
        await Task.WhenAll(tasks);

        _busy = false;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _cts.Cancel();
        _timer?.Dispose();
    }
}
