@page "/setup"
@using ElBruno.CopilotHarness.Admin.Web.Services
@using System.Text.Json
@using System.Text.Json.Nodes
@inject AdminApiClient Api
@inject IJSRuntime JS

<PageTitle>Setup Wizard</PageTitle>

<h1>Setup Wizard</h1>
<p class="muted">
    The wizard never asks for secrets here — configure model connections (including API keys) on the
    <a href="/models">Model Registry</a> page. This step picks the default model used when no routing rule matches,
    and optionally generates a starter set of routing rules.
</p>

@if (_loading)
{
    <p>Loading…</p>
}
else if (_models.Count == 0)
{
    <div class="card">
        <p>No models are configured yet.</p>
        <a href="/models"><button>Go to Model Registry</button></a>
    </div>
}
else
{
    <EditForm Model="_model" OnValidSubmit="SaveAsync">
        <div class="form-grid">
            <label>
                Default model
                <InputSelect @bind-Value="_model.DefaultModel">
                    @foreach (var model in _models)
                    {
                        <option value="@model.Name">@model.Name</option>
                    }
                </InputSelect>
            </label>
            <label class="checkbox">
                <InputCheckbox @bind-Value="_model.GenerateFirstRules" />
                Generate my first rules
            </label>
        </div>
        <button type="submit">Save setup</button>
    </EditForm>
}

@if (!string.IsNullOrWhiteSpace(_status))
{
    <p class="@(_statusOk ? "status-good-text" : "status-bad-text")">@_status</p>
}

<div class="card">
    <h2>🧠 Processor Model</h2>
    <p class="muted">
        The processor model is the local AI that evaluates your routing rules. It classifies each
        incoming prompt and selects the best rule match before routing to the cloud model.
    </p>
    @{
        var processor = _models.FirstOrDefault(m => m.IsProcessor && m.Enabled);
    }
    @if (processor is not null)
    {
        <div class="processor-info">
            <span class="processor-name">@processor.Name</span>
            <span class="processor-type-badge">@FriendlyProviderType(processor.Type)</span>
            @if (_processorStatus is not null)
            {
                <span class="processor-status-badge processor-status-@_processorStatus.Status"
                      title="@_processorStatus.Details">
                    @(StatusEmoji(_processorStatus.Status)) @(StatusLabel(_processorStatus.Status))
                </span>
            }
        </div>
        <p class="muted" style="margin-top:0.5rem">
            Model: <code>@processor.ModelName</code> · Endpoint: <code>@processor.Endpoint</code>
        </p>
        @if (_processorStatus?.Status is "unreachable" or "model-not-found")
        {
            <details class="setup-guidance">
                <summary>⚙ Get it running</summary>
                @if (processor.Type == "foundry-local")
                {
                    <div class="guidance-body">
                        <p><strong>Option 1 — Foundry Local CLI</strong></p>
                        <pre><code>winget install Microsoft.FoundryLocal
foundry model run @processor.ModelName</code></pre>
                        <p><strong>Option 2 — FoundryLocalProxy (from this repo)</strong></p>
                        <pre><code>cd C:\src\ElBruno.LLMProxies\src\proxies\FoundryLocalProxy
dotnet run</code></pre>
                        <p class="muted">Verify: <code>curl @(processor.Endpoint ?? "http://localhost:5101")/v1/models</code></p>
                    </div>
                }
                else if (processor.Type == "ollama")
                {
                    <div class="guidance-body">
                        <pre><code>winget install Ollama.Ollama
ollama pull @processor.ModelName</code></pre>
                        <p class="muted">Verify: <code>curl @(processor.Endpoint ?? "http://localhost:11434")/v1/models</code></p>
                    </div>
                }
            </details>
        }
    }
    else
    {
        <p class="status-bad-text">
            ⚠ No processor model is enabled. Routing will fall back to keyword heuristics.
        </p>
    }
    <a href="/models"><button type="button">Change processor model</button></a>
</div>

<div class="card">
    <h2>🔗 GitHub Copilot Config</h2>
    <p class="muted">
        Generate the <code>chatLanguageModels.json</code> entry for GitHub Copilot's custom endpoint. Confirm the
        Router URL you reach the harness on, copy the config, then paste it into VS Code via
        <em>Chat: Manage Language Models &rarr; Add Models &rarr; Custom Endpoint</em>.
    </p>
    <div class="form-grid">
        <label>
            Router URL
            <input type="text" @bind="_routerUrl" @bind:event="oninput" placeholder="http://localhost:5117" />
        </label>
        <label>
            Model id / label
            <input type="text" @bind="_modelId" @bind:event="oninput" placeholder="elbruno.copilotharness" />
        </label>
    </div>
    <p class="muted">
        The model id is just a label &mdash; the router selects the real model from your routing rules. VS Code asks
        for an API key on first use; any non-empty value works unless you set an admin key.
    </p>
    <div class="row">
        <button type="button" @onclick="CopyConfigAsync">Copy config</button>
        <a class="button-link" href="@ConnectPageUrl" target="_blank" rel="noopener">Open self-service page</a>
        @if (!string.IsNullOrWhiteSpace(_copyStatus))
        {
            <span class="status-good-text">@_copyStatus</span>
        }
    </div>
    <pre class="config-block">@GeneratedConfig</pre>
</div>

@code {
    private List<ModelConnectionDto> _models = [];
    private readonly SetupModel _model = new();
    private bool _loading = true;
    private string? _status;
    private bool _statusOk = true;

    private string _routerUrl = "http://localhost:5117";
    private string _modelId = "elbruno.copilotharness";
    private string? _copyStatus;

    private string ConnectPageUrl => $"{(_routerUrl ?? string.Empty).TrimEnd('/')}/connect";

    private string GeneratedConfig
    {
        get
        {
            var chatUrl = $"{(_routerUrl ?? string.Empty).TrimEnd('/')}/v1/chat/completions";
            var id = string.IsNullOrWhiteSpace(_modelId) ? "elbruno.copilotharness" : _modelId.Trim();
            var config = new JsonArray
            {
                new JsonObject
                {
                    ["name"] = "SmartRouter",
                    ["vendor"] = "customendpoint",
                    ["apiKey"] = "${input:chat.lm.secret.copilotharness}",
                    ["apiType"] = "chat-completions",
                    ["models"] = new JsonArray
                    {
                        new JsonObject
                        {
                            ["id"] = id,
                            ["name"] = id,
                            ["url"] = chatUrl,
                            ["toolCalling"] = true,
                            ["vision"] = true,
                            ["maxInputTokens"] = 128000,
                            ["maxOutputTokens"] = 16000
                        }
                    }
                }
            };
            return config.ToJsonString(new JsonSerializerOptions { WriteIndented = true });
        }
    }

    private async Task CopyConfigAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", GeneratedConfig);
            _copyStatus = "Copied!";
        }
        catch
        {
            _copyStatus = "Copy failed — select the text below and copy manually.";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _models = (await Api.GetModelsAsync()).ToList();
        var state = await Api.GetSetupStateAsync();
        _model.DefaultModel = !string.IsNullOrWhiteSpace(state.DefaultProfile)
            ? state.DefaultProfile
            : _models.FirstOrDefault()?.Name ?? string.Empty;
        _loading = false;
        // Load processor status in background without blocking page render.
        _ = LoadProcessorStatusAsync();
    }

    private async Task LoadProcessorStatusAsync()
    {
        var processor = _models.FirstOrDefault(m => m.IsProcessor && m.Enabled);
        if (processor is null || processor.Type is not ("foundry-local" or "ollama")) return;
        _processorStatus = await Api.GetModelStatusAsync(processor.Id);
        await InvokeAsync(StateHasChanged);
    }

    private ModelStatusDto? _processorStatus;

    private static string StatusEmoji(string status) => status switch
    {
        "healthy" => "✅",
        "unreachable" => "❌",
        "model-not-found" => "📥",
        _ => "—"
    };

    private static string StatusLabel(string status) => status switch
    {
        "healthy" => "Running",
        "unreachable" => "Not running",
        "model-not-found" => "Not downloaded",
        _ => status
    };

    private async Task SaveAsync()
    {
        try
        {
            var response = await Api.SaveSetupAsync(new SetupWizardRequest(
                _model.DefaultModel,
                _model.GenerateFirstRules));
            _statusOk = response.IsCompleted;
            _status = response.IsCompleted
                ? $"Setup completed. Default model: {response.DefaultProfile}."
                : "Setup not completed.";
        }
        catch (Exception ex)
        {
            _statusOk = false;
            _status = $"Setup failed: {ex.Message}";
        }
    }

    private static string FriendlyProviderType(string type) => type switch
    {
        "foundry-local" => "Foundry Local",
        "ollama" => "Ollama",
        "azure-openai" => "Azure OpenAI",
        _ => type
    };

    private sealed class SetupModel
    {
        public string DefaultModel { get; set; } = string.Empty;
        public bool GenerateFirstRules { get; set; } = true;
    }
}
