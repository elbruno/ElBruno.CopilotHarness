@page "/"
@page "/usage-analytics"
@inject IUsageTelemetryApiClient Api
@implements IAsyncDisposable

<PageTitle>Usage Analytics</PageTitle>

<section class="page-header">
    <div>
        <h1>Usage Analytics</h1>
        <p class="muted">Token usage across Foundry, Ollama, and Foundry Local with estimate-only USD for cloud rows.</p>
    </div>
    <div class="header-actions">
        <button type="button" @onclick="RefreshAsync" disabled="@_isLoading">Refresh</button>
    </div>
</section>

<section class="controls card" aria-labelledby="window-heading">
    <div class="page-header">
        <div>
            <h2 id="window-heading">Time window</h2>
            <p class="muted">Pick a preset or enter a custom UTC range.</p>
        </div>
    </div>

    <div class="window-buttons" role="tablist" aria-label="Time window presets">
        <button type="button" class="@PresetButtonClass(AnalyticsTimeWindowPreset.LastHour)" @onclick="() => SetPresetAsync(AnalyticsTimeWindowPreset.LastHour)">Last hour</button>
        <button type="button" class="@PresetButtonClass(AnalyticsTimeWindowPreset.Last24Hours)" @onclick="() => SetPresetAsync(AnalyticsTimeWindowPreset.Last24Hours)">Last 24 hours</button>
        <button type="button" class="@PresetButtonClass(AnalyticsTimeWindowPreset.Last7Days)" @onclick="() => SetPresetAsync(AnalyticsTimeWindowPreset.Last7Days)">Last 7 days</button>
        <button type="button" class="@PresetButtonClass(AnalyticsTimeWindowPreset.Custom)" @onclick="() => SetPresetAsync(AnalyticsTimeWindowPreset.Custom)">Custom</button>
    </div>

    @if (_preset == AnalyticsTimeWindowPreset.Custom)
    {
        <div class="form-grid" style="margin-top: 1rem;">
            <label>
                Start (local time)
                <input type="datetime-local" @bind="_customFromLocal" />
            </label>
            <label>
                End (local time)
                <input type="datetime-local" @bind="_customToLocal" />
            </label>
        </div>
        <button type="button" @onclick="RefreshAsync" disabled="@_isLoading">Apply custom range</button>
    }
    else
    {
        <p class="muted">Current range: @_summaryWindowLabel</p>
    }
</section>

@if (_isLoading)
{
    <section class="card" role="status" aria-live="polite">
        <p>Loading usage analytics…</p>
    </section>
}
else
{
    @if (!string.IsNullOrWhiteSpace(_summaryError))
    {
        <section class="card error-card" role="alert">
            <h2>Usage summary unavailable</h2>
            <p>@_summaryError</p>
        </section>
    }
    else if (_summary is not null)
    {
        <section class="summary-grid" aria-label="Overall usage summary">
            <article class="card metric-card">
                <h2>Events</h2>
                <p class="metric">@_summary.EventCount</p>
                <p class="muted">Requests with token telemetry</p>
            </article>
            <article class="card metric-card">
                <h2>Input tokens</h2>
                <p class="metric">@FormatLong(_summary.InputTokens)</p>
            </article>
            <article class="card metric-card">
                <h2>Output tokens</h2>
                <p class="metric">@FormatLong(_summary.OutputTokens)</p>
            </article>
            <article class="card metric-card">
                <h2>Total tokens</h2>
                <p class="metric">@FormatLong(_summary.TotalTokens)</p>
            </article>
            <article class="card metric-card">
                <h2>Estimated USD</h2>
                <p class="metric">@FormatUsd(_summary.EstimatedUsdTotal)</p>
                <p class="muted">Estimate only; not billed cost.</p>
            </article>
        </section>

        <section class="card" aria-labelledby="freshness-heading">
            <div class="page-header">
                <div>
                    <h2 id="freshness-heading">Freshness</h2>
                    <p class="muted">Last successful refresh is tracked locally by the dashboard.</p>
                </div>
                <span class="status-pill @FreshnessClass()">@FreshnessLabel()</span>
            </div>
            <p>
                Last refreshed:
                <strong>@(_lastSuccessfulRefreshUtc is null ? "never" : FormatUtc(_lastSuccessfulRefreshUtc.Value))</strong>
            </p>
            <p>
                Data window:
                <strong>@FormatUtc(_summary.FromUtc)</strong>
                to
                <strong>@FormatUtc(_summary.ToUtc)</strong>
            </p>
            <p class="muted">@_summary.EstimateDisclaimer</p>
            @if (_summary.HasEstimateGaps)
            {
                <p class="warning-text">Some rows are token-only because pricing cards were not available.</p>
            }
        </section>

        <section class="card" aria-labelledby="breakdown-heading">
            <div class="page-header">
                <div>
                    <h2 id="breakdown-heading">Per-proxy / per-model breakdown</h2>
                    <p class="muted">Cloud rows show estimated USD. Ollama and Foundry Local stay token-only.</p>
                </div>
            </div>

            @if (_summary.Rows.Count == 0)
            {
                <div class="empty-state" role="status">
                    <h3>No usage telemetry yet</h3>
                    <p>The selected window did not return any analytics rows.</p>
                </div>
            }
            else
            {
                @foreach (var proxyGroup in GetProxyGroups())
                {
                    <article class="proxy-group">
                        <div class="proxy-header">
                            <div>
                                <h3>@proxyGroup.DisplayName</h3>
                                <p class="muted">@proxyGroup.TotalTokens tokens across @proxyGroup.RowCount rows</p>
                            </div>
                        </div>

                        @if (proxyGroup.Rows.Count == 0)
                        {
                            <p class="muted">No rows were returned for this proxy in the selected window.</p>
                        }
                        else
                        {
                            <table>
                                <thead>
                                    <tr>
                                        <th scope="col">Model</th>
                                        <th scope="col">Provider</th>
                                        <th scope="col">Events</th>
                                        <th scope="col">Input</th>
                                        <th scope="col">Output</th>
                                        <th scope="col">Total</th>
                                        <th scope="col">Cost</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in proxyGroup.Rows)
                                    {
                                        <tr>
                                            <td>@row.Model</td>
                                            <td>@row.Provider</td>
                                            <td>@row.EventCount</td>
                                            <td>@FormatLong(row.InputTokens)</td>
                                            <td>@FormatLong(row.OutputTokens)</td>
                                            <td>@FormatLong(row.TotalTokens)</td>
                                            <td>
                                                <span class="@CostLabelClass(row)">@CostLabel(row)</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </article>
                }
            }
        </section>
    }
}

<section class="card" aria-labelledby="pricing-heading">
    <div class="page-header">
        <div>
            <h2 id="pricing-heading">Pricing catalog snapshot</h2>
            <p class="muted">Pulled from the pricing endpoint for operator clarity.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_pricingError))
    {
        <p class="warning-text">@_pricingError</p>
    }
    else if (_pricingCards.Count == 0)
    {
        <p class="muted">No pricing cards are configured for this window.</p>
    }
    else
    {
        <p class="muted">@_pricingCards.Count pricing cards loaded (@_pricingCards.Count(card => card.IsOverride) overrides).</p>
        <table>
            <thead>
                <tr>
                    <th scope="col">Provider</th>
                    <th scope="col">Model</th>
                    <th scope="col">Operation</th>
                    <th scope="col">Input / 1M</th>
                    <th scope="col">Output / 1M</th>
                    <th scope="col">Source</th>
                    <th scope="col">Effective</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var card in _pricingCards.OrderBy(card => card.Provider).ThenBy(card => card.Model))
                {
                    <tr>
                        <td>@card.Provider</td>
                        <td>@card.Model</td>
                        <td>@card.Operation</td>
                        <td>@FormatUsd(card.InputUsdPer1MToken)</td>
                        <td>@FormatUsd(card.OutputUsdPer1MToken)</td>
                        <td>@card.SourceType</td>
                        <td>@FormatUtc(card.EffectiveFromUtc)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code {
    private readonly CancellationTokenSource _refreshCancellation = new();
    private AnalyticsTimeWindowPreset _preset = AnalyticsTimeWindowPreset.Last24Hours;
    private DateTime _customFromLocal = DateTime.Now.AddDays(-1);
    private DateTime _customToLocal = DateTime.Now;
    private UsageTelemetrySummaryResponse? _summary;
    private IReadOnlyList<UsagePricingCardResponse> _pricingCards = [];
    private string? _summaryError;
    private string? _pricingError;
    private bool _isLoading = true;
    private DateTimeOffset? _lastSuccessfulRefreshUtc;
    private string _summaryWindowLabel = "Last 24 hours";

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task SetPresetAsync(AnalyticsTimeWindowPreset preset)
    {
        _preset = preset;
        if (preset != AnalyticsTimeWindowPreset.Custom)
        {
            await RefreshAsync();
        }
    }

    private async Task RefreshAsync()
    {
        _isLoading = true;
        _summaryError = null;
        _pricingError = null;
        StateHasChanged();

        var (fromUtc, toUtc) = ResolveWindow();
        _summaryWindowLabel = $"{FormatUtc(fromUtc)} → {FormatUtc(toUtc)}";

        Task<UsageTelemetrySummaryResponse>? summaryTask = null;
        Task<IReadOnlyList<UsagePricingCardResponse>>? pricingTask = null;

        try
        {
            summaryTask = Api.GetSummaryAsync(fromUtc, toUtc, _refreshCancellation.Token);
        }
        catch (Exception exception)
        {
            _summary = null;
            _summaryError = $"Could not load usage summary: {exception.Message}";
        }

        try
        {
            pricingTask = Api.GetPricingCardsAsync(_refreshCancellation.Token);
        }
        catch (Exception exception)
        {
            _pricingCards = [];
            _pricingError = $"Could not load pricing cards: {exception.Message}";
        }

        if (summaryTask is not null)
        {
            try
            {
                _summary = await summaryTask;
                _lastSuccessfulRefreshUtc = DateTimeOffset.UtcNow;
            }
            catch (Exception exception)
            {
                _summary = null;
                _summaryError = $"Could not load usage summary: {exception.Message}";
            }
        }

        if (pricingTask is not null)
        {
            try
            {
                _pricingCards = await pricingTask;
            }
            catch (Exception exception)
            {
                _pricingCards = [];
                _pricingError = $"Could not load pricing cards: {exception.Message}";
            }
        }

        _isLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private (DateTimeOffset FromUtc, DateTimeOffset ToUtc) ResolveWindow()
    {
        var now = DateTimeOffset.UtcNow;
        return _preset switch
        {
            AnalyticsTimeWindowPreset.LastHour => (now.AddHours(-1), now),
            AnalyticsTimeWindowPreset.Last24Hours => (now.AddDays(-1), now),
            AnalyticsTimeWindowPreset.Last7Days => (now.AddDays(-7), now),
            AnalyticsTimeWindowPreset.Custom => ParseCustomWindow(now),
            _ => (now.AddDays(-1), now)
        };
    }

    private (DateTimeOffset FromUtc, DateTimeOffset ToUtc) ParseCustomWindow(DateTimeOffset fallbackToUtc)
    {
        var from = DateTime.SpecifyKind(_customFromLocal, DateTimeKind.Local);
        var to = DateTime.SpecifyKind(_customToLocal, DateTimeKind.Local);
        var fromUtc = new DateTimeOffset(from).ToUniversalTime();
        var toUtc = new DateTimeOffset(to).ToUniversalTime();
        if (toUtc <= fromUtc)
        {
            return (fallbackToUtc.AddDays(-1), fallbackToUtc);
        }

        return (fromUtc, toUtc);
    }

    private IReadOnlyList<ProxyGroupView> GetProxyGroups()
    {
        var rows = _summary?.Rows ?? [];
        var groups = rows
            .GroupBy(row => row.Proxy, StringComparer.OrdinalIgnoreCase)
            .Select(group => new ProxyGroupView(
                group.Key,
                group.OrderBy(row => row.Provider, StringComparer.OrdinalIgnoreCase).ThenBy(row => row.Model, StringComparer.OrdinalIgnoreCase).ToList(),
                group.Sum(row => row.TotalTokens)))
            .OrderBy(group => ProxySortOrder(group.Proxy))
            .ThenBy(group => group.Proxy, StringComparer.OrdinalIgnoreCase)
            .ToList();

        return new[]
        {
            new ProxyGroupView("FoundryProxy", groups.FirstOrDefault(group => IsProxy(group.Proxy, "FoundryProxy"))?.Rows ?? [], groups.FirstOrDefault(group => IsProxy(group.Proxy, "FoundryProxy"))?.TotalTokens ?? 0),
            new ProxyGroupView("OllamaProxy", groups.FirstOrDefault(group => IsProxy(group.Proxy, "OllamaProxy"))?.Rows ?? [], groups.FirstOrDefault(group => IsProxy(group.Proxy, "OllamaProxy"))?.TotalTokens ?? 0),
            new ProxyGroupView("FoundryLocalProxy", groups.FirstOrDefault(group => IsProxy(group.Proxy, "FoundryLocalProxy"))?.Rows ?? [], groups.FirstOrDefault(group => IsProxy(group.Proxy, "FoundryLocalProxy"))?.TotalTokens ?? 0)
        };
    }

    private static bool IsProxy(string actual, string expected) =>
        string.Equals(actual, expected, StringComparison.OrdinalIgnoreCase);

    private static int ProxySortOrder(string proxy) => proxy.ToLowerInvariant() switch
    {
        "foundryproxy" => 0,
        "ollamaproxy" => 1,
        "foundrylocalproxy" => 2,
        _ => 3
    };

    private static string FormatLong(long value) => value.ToString("N0", CultureInfo.InvariantCulture);

    private static string FormatUsd(double value) => value.ToString("C4", CultureInfo.GetCultureInfo("en-US"));

    private static string FormatUtc(DateTimeOffset value) => value.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss 'UTC'", CultureInfo.InvariantCulture);

    private static string CostLabel(UsageTelemetrySummaryRowResponse row)
    {
        if (IsTokenOnlyRow(row))
        {
            return row.Provider.Contains("ollama", StringComparison.OrdinalIgnoreCase)
                ? "Token-only: Ollama"
                : "Token-only: Foundry Local";
        }

        if (row.EstimateAvailable && row.EstimatedUsd.HasValue)
        {
            return $"Estimated USD: {FormatUsd(row.EstimatedUsd.Value)}";
        }

        return $"Cloud row: estimate unavailable ({row.EstimateUnavailableReason ?? "unknown"})";
    }

    private static string CostLabelClass(UsageTelemetrySummaryRowResponse row) =>
        IsTokenOnlyRow(row) ? "status-pill status-neutral" : row.EstimateAvailable ? "status-pill status-good" : "status-pill status-warn";

    private static bool IsTokenOnlyRow(UsageTelemetrySummaryRowResponse row) =>
        IsLocalProvider(row.Provider) || IsLocalProxy(row.Proxy);

    private static bool IsLocalProvider(string provider) =>
        provider.Contains("ollama", StringComparison.OrdinalIgnoreCase) ||
        provider.Contains("foundry_local", StringComparison.OrdinalIgnoreCase) ||
        provider.Contains("foundrylocal", StringComparison.OrdinalIgnoreCase);

    private static bool IsLocalProxy(string proxy) =>
        proxy.Contains("OllamaProxy", StringComparison.OrdinalIgnoreCase) ||
        proxy.Contains("FoundryLocalProxy", StringComparison.OrdinalIgnoreCase);

    private string PresetButtonClass(AnalyticsTimeWindowPreset preset) =>
        _preset == preset ? "status-pill status-good window-button active" : "status-pill status-neutral window-button";

    private string FreshnessLabel()
    {
        if (_lastSuccessfulRefreshUtc is null)
        {
            return "Cold";
        }

        var age = DateTimeOffset.UtcNow - _lastSuccessfulRefreshUtc.Value;
        if (age < TimeSpan.FromMinutes(1))
        {
            return "Fresh";
        }

        if (age < TimeSpan.FromMinutes(5))
        {
            return "Recent";
        }

        return "Stale";
    }

    private string FreshnessClass() => FreshnessLabel() switch
    {
        "Fresh" => "status-good",
        "Recent" => "status-warn",
        "Stale" => "status-bad",
        _ => "status-neutral"
    };

    public async ValueTask DisposeAsync()
    {
        _refreshCancellation.Cancel();
        _refreshCancellation.Dispose();
        await Task.CompletedTask;
    }

    private sealed record ProxyGroupView(string Proxy, IReadOnlyList<UsageTelemetrySummaryRowResponse> Rows, long TotalTokens)
    {
        public string DisplayName => Proxy switch
        {
            "FoundryProxy" => "Foundry",
            "OllamaProxy" => "Ollama",
            "FoundryLocalProxy" => "Foundry Local",
            _ => Proxy
        };
        public int RowCount => Rows.Count;
    }
}

@code {
    private enum AnalyticsTimeWindowPreset
    {
        LastHour,
        Last24Hours,
        Last7Days,
        Custom
    }
}
