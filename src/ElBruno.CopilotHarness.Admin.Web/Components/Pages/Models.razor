@page "/models"
@using ElBruno.CopilotHarness.Admin.Web.Services
@inject AdminApiClient Api

<PageTitle>Model Registry</PageTitle>

<div class="page-header">
    <div>
        <h1>Model Registry</h1>
        <p class="muted">
            A registry of real LLM connections. Each model has its own provider type, endpoint, model/deployment name,
            and (for Azure OpenAI / Foundry) an API key that is encrypted at rest. Routing rules reference these models by name.
        </p>
    </div>
</div>

@if (_loading)
{
    <p>Loading models…</p>
}
else
{
    <div class="dashboard-actions">
        <button @onclick="StartCreate">➕ Add model</button>
        <span class="muted">Default model:</span>
        <select value="@_defaultModel" @onchange="OnDefaultChanged">
            @foreach (var model in _models)
            {
                <option value="@model.Name">@model.Name</option>
            }
        </select>
    </div>

    @if (_models.Count == 0)
    {
        <p class="muted">No models configured yet. Add your first connection.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Endpoint</th>
                    <th>Model / Deployment</th>
                    <th>API key</th>
                    <th>Processor</th>
                    <th>Custom temp</th>
                    <th>Tools</th>
                    <th>Enabled</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var model in _models)
                {
                    <tr>
                        <td><strong>@model.Name</strong>@(model.Name == _defaultModel ? " ⭐" : "")</td>
                        <td>@FriendlyType(model.Type)</td>
                        <td class="muted">@(string.IsNullOrWhiteSpace(model.Endpoint) ? "(shared Foundry)" : model.Endpoint)</td>
                        <td>@model.ModelName</td>
                        <td>
                            @if (model.Type == "ollama" || model.Type == "foundry-local")
                            {
                                <span class="muted">n/a</span>
                            }
                            else
                            {
                                <span class="status-pill @(model.HasApiKey ? "status-good" : "status-warn")">
                                    @(model.HasApiKey ? "set" : "none")
                                </span>
                            }
                        </td>
                        <td>
                            <span class="status-pill @(model.Enabled ? "status-good" : "status-neutral")">
                                @(model.Enabled ? "enabled" : "disabled")
                            </span>
                        </td>
                        <td>
                            @if (model.IsProcessor)
                            {
                                <span class="status-pill status-good" title="Classifier model that reads the first chars of each prompt">🧠 processor</span>
                            }
                            else
                            {
                                <span class="muted">—</span>
                            }
                        </td>
                        <td>
                            <span class="status-pill @(model.SupportsCustomTemperature ? "status-neutral" : "status-warn")"
                                  title="@(model.SupportsCustomTemperature ? "Accepts custom temperature/top_p" : "Non-default temperature/top_p stripped before forwarding")">
                                @(model.SupportsCustomTemperature ? "yes" : "default-only")
                            </span>
                        </td>
                        <td>
                            @if (model.SupportsToolCalling)
                            {
                                <span class="status-pill status-neutral" title="Can serve agentic / tool-calling requests">🛠 tools</span>
                            }
                            else
                            {
                                <span class="status-pill status-warn" title="Cannot serve tool-calling requests — those are re-routed to a tool-capable model">no tools</span>
                            }
                        </td>
                        <td class="col-actions">
                            @if (_confirmDeleteId == model.Id)
                            {
                                <span class="muted">Delete '@model.Name'?</span>
                                <button class="btn-reject btn-sm" @onclick="() => ConfirmDeleteAsync(model)">Yes</button>
                                <button class="btn-ghost btn-sm" @onclick="() => _confirmDeleteId = null">No</button>
                            }
                            else
                            {
                                <button class="btn-approve" @onclick="() => StartEdit(model)">Edit</button>
                                <button @onclick="() => TestAsync(model)">Test</button>
                                <button class="btn-reject" @onclick="() => _confirmDeleteId = model.Id">Delete</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@if (_editor is not null)
{
    <div class="modal-backdrop" @onclick="CancelEdit"></div>
    <div class="modal" role="dialog" aria-modal="true">
        <div class="modal-head">
            <h2>@(_isNew ? "➕ Add model" : $"Edit '{_editorName}'")</h2>
            <button class="modal-close" @onclick="CancelEdit" title="Close">✕</button>
        </div>
        <EditForm Model="_editor" OnValidSubmit="SaveAsync">
            <div class="modal-body">
                <div class="form-grid">
                    <label>
                        Display name
                        <InputText @bind-Value="_editor.Name" placeholder="e.g. foundry gpt-5.5" />
                    </label>
                    <label>
                        Provider type
                        <InputSelect @bind-Value="_editor.Type">
                            <option value="azure-openai">Azure OpenAI / Foundry</option>
                            <option value="ollama">Ollama</option>
                            <option value="foundry-local">Foundry Local</option>
                        </InputSelect>
                    </label>
                    <label class="span-2">
                        Endpoint
                        <InputText @bind-Value="_editor.Endpoint"
                                   placeholder="@(_editor.Type == "ollama" ? "http://localhost:11434" : _editor.Type == "foundry-local" ? "http://localhost:5101" : "https://my-resource.openai.azure.com (blank = shared Foundry)")" />
                    </label>
                    <label>
                        @(_editor.Type == "ollama" || _editor.Type == "foundry-local" ? "Model name" : "Deployment name")
                        <InputText @bind-Value="_editor.ModelName"
                                   placeholder="@(_editor.Type == "ollama" ? "llama3.1:8b" : _editor.Type == "foundry-local" ? "phi-4-mini" : "gpt-5-mini")" />
                    </label>
                    @if (_editor.Type != "ollama" && _editor.Type != "foundry-local")
                    {
                        <label>
                            API version
                            <InputText @bind-Value="_editor.ApiVersion" placeholder="2024-10-21" />
                        </label>
                        <label class="span-2">
                            API key
                            <InputText type="password" @bind-Value="_editor.ApiKey"
                                       placeholder="@(_isNew ? "paste key" : "leave blank to keep, type to replace")" />
                        </label>
                    }
                    <label class="checkbox span-2">
                        <InputCheckbox @bind-Value="_editor.Enabled" /> Enabled
                    </label>
                    <label class="checkbox span-2">
                        <InputCheckbox @bind-Value="_editor.IsProcessor" /> Processor model (classifier)
                        <span class="field-hint">— reads the first chars of each prompt to decide intent. Only one model can be the processor.</span>
                    </label>
                    <label class="checkbox span-2">
                        <InputCheckbox @bind-Value="_editor.SupportsCustomTemperature" /> Supports custom temperature
                        <span class="field-hint">— uncheck for gpt-5 family models that only accept the default temperature.</span>
                    </label>
                    <label class="checkbox span-2">
                        <InputCheckbox @bind-Value="_editor.SupportsToolCalling" /> Supports tool-calling
                        <span class="field-hint">— uncheck for small local models that can't serve agentic / tool-calling requests; those get re-routed to a tool-capable model.</span>
                    </label>
                </div>
            </div>
            <div class="modal-foot">
                <button type="submit" class="btn-approve">@(_isNew ? "Create" : "Save")</button>
                <button type="button" class="btn-reject" @onclick="CancelEdit">Cancel</button>
            </div>
        </EditForm>
    </div>
}

@if (!string.IsNullOrWhiteSpace(_status))
{
    <p class="@(_statusOk ? "status-good-text" : "status-bad-text")">@_status</p>
}

@code {
    private List<ModelConnectionDto> _models = [];
    private string _defaultModel = string.Empty;
    private bool _loading = true;
    private string? _status;
    private bool _statusOk = true;

    private ModelEditor? _editor;
    private bool _isNew;
    private string? _editorId;
    private string _editorName = string.Empty;
    private string? _confirmDeleteId;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _models = (await Api.GetModelsAsync()).ToList();
        _defaultModel = (await Api.GetDefaultModelAsync()).ModelName;
        _loading = false;
    }

    private void StartCreate()
    {
        _confirmDeleteId = null;
        _isNew = true;
        _editorId = null;
        _editorName = string.Empty;
        _editor = new ModelEditor { Type = "azure-openai", ApiVersion = "2024-10-21", Enabled = true, SupportsCustomTemperature = true, SupportsToolCalling = true };
    }

    private void StartEdit(ModelConnectionDto model)
    {
        _confirmDeleteId = null;
        _isNew = false;
        _editorId = model.Id;
        _editorName = model.Name;
        _editor = new ModelEditor
        {
            Name = model.Name,
            Type = model.Type,
            Endpoint = model.Endpoint,
            ModelName = model.ModelName,
            ApiVersion = string.IsNullOrWhiteSpace(model.ApiVersion) ? "2024-10-21" : model.ApiVersion,
            ApiKey = null,
            Enabled = model.Enabled,
            IsProcessor = model.IsProcessor,
            SupportsCustomTemperature = model.SupportsCustomTemperature,
            SupportsToolCalling = model.SupportsToolCalling
        };
    }

    private void CancelEdit() => _editor = null;

    private async Task SaveAsync()
    {
        if (_editor is null)
        {
            return;
        }

        try
        {
            var request = new ModelConnectionUpsertRequest(
                _editor.Name,
                _editor.Type,
                _editor.Endpoint ?? string.Empty,
                _editor.ModelName ?? string.Empty,
                _editor.ApiVersion ?? string.Empty,
                _editor.ApiKey,
                _editor.Enabled,
                _editor.IsProcessor,
                _editor.SupportsCustomTemperature,
                _editor.SupportsToolCalling);

            if (_isNew)
            {
                await Api.CreateModelAsync(request);
                SetStatus($"Created model '{_editor.Name}'.", true);
            }
            else
            {
                await Api.UpdateModelAsync(_editorId!, request);
                SetStatus($"Saved model '{_editor.Name}'.", true);
            }

            _editor = null;
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            SetStatus($"Save failed: {ex.Message}", false);
        }
    }

    private async Task ConfirmDeleteAsync(ModelConnectionDto model)
    {
        try
        {
            await Api.DeleteModelAsync(model.Id);
            _confirmDeleteId = null;
            SetStatus($"Deleted model '{model.Name}'.", true);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            SetStatus($"Delete failed: {ex.Message}", false);
        }
    }

    private async Task TestAsync(ModelConnectionDto model)
    {
        SetStatus($"Testing '{model.Name}'…", true);
        var result = await Api.TestModelAsync(model.Id);
        SetStatus($"{model.Name}: {result.Message} ({result.LatencyMs:F0} ms)", result.Success);
    }

    private async Task OnDefaultChanged(ChangeEventArgs e)
    {
        var name = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(name))
        {
            return;
        }

        await Api.SetDefaultModelAsync(name);
        _defaultModel = name;
        SetStatus($"Default model set to '{name}'.", true);
    }

    private void SetStatus(string message, bool ok)
    {
        _status = message;
        _statusOk = ok;
    }

    private static string FriendlyType(string type) =>
        type switch
        {
            "ollama" => "Ollama",
            "azure-openai" => "Azure OpenAI / Foundry",
            "foundry-local" => "Foundry Local",
            _ => type
        };

    private sealed class ModelEditor
    {
        public string Name { get; set; } = string.Empty;
        public string Type { get; set; } = "azure-openai";
        public string? Endpoint { get; set; }
        public string? ModelName { get; set; }
        public string? ApiVersion { get; set; } = "2024-10-21";
        public string? ApiKey { get; set; }
        public bool Enabled { get; set; } = true;
        public bool IsProcessor { get; set; }
        public bool SupportsCustomTemperature { get; set; } = true;
        public bool SupportsToolCalling { get; set; } = true;
    }
}
