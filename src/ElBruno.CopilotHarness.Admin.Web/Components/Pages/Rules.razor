@page "/rules"
@inject ElBruno.CopilotHarness.Admin.Web.Services.AdminApiClient Api

<PageTitle>Rules Editor</PageTitle>

<h1>Rules Editor</h1>
<p>Phase 2 supports deterministic basic routing rules. Rule confidence indicators are provided by the Phase 8 Recommendation Agent.</p>

<button @onclick="GenerateStarterRulesAsync">Generate my first rules</button>

@if (_model is null)
{
    <p>Loading rules...</p>
}
else
{
    <EditForm Model="_model" OnValidSubmit="SaveAsync">
        <div class="form-grid">
            <label>Default profile <InputText @bind-Value="_model.DefaultProfile" /></label>
            <label>Big prompt threshold <InputNumber @bind-Value="_model.BigPromptCharacterThreshold" /></label>
            <label>Big profile <InputText @bind-Value="_model.BigProfile" /></label>
            <label>Streaming profile <InputText @bind-Value="_model.StreamingProfile" /></label>
            <label class="checkbox"><InputCheckbox @bind-Value="_model.PreferBigWhenSystemMessageExists" /> Prefer big when system exists</label>
            <label class="checkbox"><InputCheckbox @bind-Value="_model.PreferStreamingProfileWhenStreaming" /> Prefer streaming profile</label>
        </div>
        <button type="submit">Save rules</button>
    </EditForm>
}

@if (!string.IsNullOrWhiteSpace(_status))
{
    <p>@_status</p>
}

@if (_confidence is not null && _confidence.Items.Count > 0)
{
    <h2>Rule confidence</h2>
    <p class="muted">Confidence levels from the Phase 8 Recommendation Agent. High confidence rules are well-supported by benchmark data.</p>
    <div class="model-list">
        @foreach (var item in _confidence.Items)
        {
            <div class="card confidence-row">
                <div class="approval-header">
                    <strong>@item.RuleKey</strong>
                    <span class="confidence-pill @GetConfidenceClass(item.Confidence)">
                        @FormatConfidence(item.Confidence)
                    </span>
                    <span class="muted">@item.Trend</span>
                </div>
                <div class="confidence-bar-track">
                    <div class="confidence-bar-fill @GetConfidenceClass(item.Confidence)"
                         style="width: @(Math.Round(item.Confidence * 100))%"></div>
                </div>
                <p class="muted">Last evaluated @item.LastEvaluatedAtUtc.ToLocalTime().ToString("u")</p>
            </div>
        }
    </div>
}

@code {
    private MutableRules? _model;
    private string? _status;
    private ElBruno.CopilotHarness.Admin.Web.Services.RulesConfidenceResponse? _confidence;

    protected override async Task OnInitializedAsync()
    {
        _model = new MutableRules(await Api.GetBasicRulesAsync());
        _confidence = await Api.GetRulesConfidenceAsync();
    }

    private async Task GenerateStarterRulesAsync()
    {
        await Api.GenerateFirstRulesAsync();
        _model = new MutableRules(await Api.GetBasicRulesAsync());
        _status = "Starter rules generated.";
    }

    private async Task SaveAsync()
    {
        if (_model is null)
        {
            return;
        }

        var updated = await Api.UpdateBasicRulesAsync(new(
            _model.DefaultProfile,
            _model.BigPromptCharacterThreshold,
            _model.BigProfile,
            _model.StreamingProfile,
            _model.PreferBigWhenSystemMessageExists,
            _model.PreferStreamingProfileWhenStreaming));
        _model = new MutableRules(updated);
        _status = $"Rules updated at {updated.UpdatedAtUtc:O}.";
    }

    private sealed class MutableRules
    {
        public MutableRules(BasicRulesDto source)
        {
            DefaultProfile = source.DefaultProfile;
            BigPromptCharacterThreshold = source.BigPromptCharacterThreshold;
            BigProfile = source.BigProfile;
            StreamingProfile = source.StreamingProfile;
            PreferBigWhenSystemMessageExists = source.PreferBigWhenSystemMessageExists;
            PreferStreamingProfileWhenStreaming = source.PreferStreamingProfileWhenStreaming;
        }

        public string DefaultProfile { get; set; }
        public int BigPromptCharacterThreshold { get; set; }
        public string BigProfile { get; set; }
        public string StreamingProfile { get; set; }
        public bool PreferBigWhenSystemMessageExists { get; set; }
        public bool PreferStreamingProfileWhenStreaming { get; set; }
    }

    private static string GetConfidenceClass(double confidence) =>
        confidence switch
        {
            >= 0.8 => "confidence-high",
            >= 0.5 => "confidence-medium",
            _ => "confidence-low"
        };

    private static string FormatConfidence(double confidence) =>
        $"{Math.Round(confidence * 100)}%";
}
