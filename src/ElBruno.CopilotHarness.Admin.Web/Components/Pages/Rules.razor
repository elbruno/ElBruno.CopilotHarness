@page "/rules"
@using ElBruno.CopilotHarness.Admin.Web.Services
@inject AdminApiClient Api

<PageTitle>Rules Editor</PageTitle>

<h1>Rules Editor</h1>
<p class="muted">
    Routing rules can match deterministic request conditions or semantic natural-language paragraphs. Rules are
    evaluated by ascending priority; the first match wins. For semantic rules, the highest-priority enabled rule
    should be the catch-all.
</p>

@if (_loading)
{
    <p>Loading rules…</p>
}
else
{
    <div class="dashboard-actions">
        <button @onclick="StartCreateSemantic">🧠 Add semantic rule</button>
        <button @onclick="StartCreate">⚙️ Add condition rule</button>
        @if (_rules.Count == 0)
        {
            <button class="btn-approve" @onclick="GenerateStarterRulesAsync">✨ Generate starter rules</button>
        }
    </div>

    @if (_rules.Count == 0)
    {
        <p class="muted">No rules yet. Use the wizard to generate a sensible starter set, or add one manually.</p>
    }
    else
    {
        <table class="rules-table">
            <thead>
                <tr>
                    <th class="col-pri">Order</th>
                    <th>Rule</th>
                    <th>Match</th>
                    <th>Routes to</th>
                    <th class="col-state">State</th>
                    <th class="col-actions"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rule in _rules)
                {
                    var badge = EngineBadge(rule.TargetModel);
                    <tr class="@(rule.Enabled ? "" : "row-disabled")">
                        <td class="col-pri"><span class="pri-chip">@rule.Priority</span></td>
                        <td>
                            <div class="rule-name">
                                @if (IsSemantic(rule.ConditionType))
                                {
                                    <span class="type-chip type-semantic" title="Semantic rule – chosen by the local model">🧠 semantic</span>
                                }
                                else
                                {
                                    <span class="type-chip type-condition" title="Deterministic condition rule">⚙️ condition</span>
                                }
                                <strong>@rule.Name</strong>
                            </div>
                            <span class="muted rule-desc">@rule.Description</span>
                        </td>
                        <td class="muted">@DescribeCondition(rule)</td>
                        <td>
                            <span class="engine-badge @badge.Css" title="@badge.Title">@badge.Icon @rule.TargetModel</span>
                        </td>
                        <td class="col-state">
                            <button class="toggle @(rule.Enabled ? "toggle-on" : "toggle-off")"
                                    title="@(rule.Enabled ? "Click to disable" : "Click to enable")"
                                    @onclick="() => ToggleEnabledAsync(rule)">
                                @(rule.Enabled ? "● on" : "○ off")
                            </button>
                        </td>
                        <td class="col-actions">
                            <button class="btn-approve" @onclick="() => StartEdit(rule)">Edit</button>
                            <button class="btn-reject" @onclick="() => DeleteAsync(rule)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <p class="muted hint">Rules evaluate top-to-bottom by <strong>Order</strong> (ascending priority). For semantic rules the
            highest-order enabled rule acts as the catch-all. Drag is not needed — edit a rule's <em>Order</em> to reposition it.</p>
    }

    @* ── Local analyzer prompt (the "big prompt" the local model uses) ── *@
    <div class="card analyzer-card">
        <div class="analyzer-head">
            <button class="link-toggle" @onclick="() => _showAnalyzer = !_showAnalyzer">
                @(_showAnalyzer ? "▾" : "▸") 🧠 Local analyzer prompt
            </button>
            @if (_analyzerPrompt is not null)
            {
                <span class="muted analyzer-meta">
                    @if (_analyzerPrompt.HasProcessorModel)
                    {
                        <span>processor model: <strong>@_analyzerPrompt.ProcessorModel</strong></span>
                    }
                    else
                    {
                        <span class="status-bad-text">no processor model selected</span>
                    }
                    · @_analyzerPrompt.SemanticRuleCount semantic rule(s)
                </span>
            }
        </div>
        <p class="muted">This is the exact instruction prompt sent to the local processor model. It reads only the user's typed
            request and returns the one rule that best matches — that rule's engine then receives the full Copilot payload.</p>
        @if (_showAnalyzer && _analyzerPrompt is not null)
        {
            <pre class="prompt-block">@_analyzerPrompt.SystemPrompt</pre>
        }
    </div>
}

@if (!string.IsNullOrWhiteSpace(_status))
{
    <p class="@(_statusOk ? "status-good-text" : "status-bad-text")">@_status</p>
}

@* ── Test the ruleset ── *@
<div class="card test-card">
    <h2>🧪 Test the ruleset</h2>
    <p class="muted">Enter a sample user request to see which rule the local model picks and which engine it routes to.</p>
    <EditForm Model="_test" OnValidSubmit="RunTestAsync">
        <div class="form-grid">
            <label class="span-2">
                User request
                <InputTextArea @bind-Value="_test.Prompt" rows="3" placeholder="e.g. hi  ·  commit and push  ·  refactor the auth module" />
            </label>
            <label>
                System message (optional)
                <InputTextArea @bind-Value="_test.SystemMessage" rows="2" />
            </label>
            <label>
                Requested model (optional)
                <InputText @bind-Value="_test.RequestedModel" />
            </label>
            <label class="checkbox">
                <InputCheckbox @bind-Value="_test.Stream" /> Streaming request
            </label>
        </div>
        <button type="submit" disabled="@_testRunning">@(_testRunning ? "Running…" : "Run test")</button>
    </EditForm>

    @if (_testResult is not null)
    {
        var tb = EngineBadge(_testResult.SelectedModel);
        <div class="card test-result">
            <div class="result-flow">
                <div class="flow-step">
                    <span class="flow-label">User request</span>
                    <span class="flow-value">@(_testResult.UserRequest ?? _test.Prompt)</span>
                </div>
                <span class="flow-arrow">→</span>
                <div class="flow-step">
                    <span class="flow-label">Matched rule</span>
                    <span class="flow-value">@(_testResult.MatchedRuleName ?? "(none — default/fallback)")</span>
                </div>
                <span class="flow-arrow">→</span>
                <div class="flow-step">
                    <span class="flow-label">Engine</span>
                    <span class="flow-value engine-badge @tb.Css">@tb.Icon @_testResult.SelectedModel</span>
                </div>
            </div>
            <div class="result-meta">
                <span class="meta-chip">@(_testResult.IsSemantic ? "🧠 semantic" : "⚙️ condition")</span>
                <span class="meta-chip" title="How the decision was made">source: @DescribeSource(_testResult.DecisionSource)</span>
                @if (_testResult.Confidence > 0)
                {
                    <span class="meta-chip">confidence: @FormatConfidence(_testResult.Confidence)</span>
                }
                @if (!_testResult.IsSemantic && !string.IsNullOrWhiteSpace(_testResult.ClassificationIntent))
                {
                    <span class="meta-chip">intent: @_testResult.ClassificationIntent / @_testResult.ClassificationComplexity</span>
                }
                <span class="meta-chip">@_testResult.PromptCharacters chars</span>
            </div>
            <p class="result-reason">@(_testResult.SemanticReason ?? _testResult.Reason)</p>
            @if (!string.IsNullOrWhiteSpace(_testResult.AnalyzerPrompt))
            {
                <button class="link-toggle" @onclick="() => _showTestPrompt = !_showTestPrompt">
                    @(_showTestPrompt ? "▾" : "▸") Show the analyzer prompt used for this test
                </button>
                @if (_showTestPrompt)
                {
                    <pre class="prompt-block">@_testResult.AnalyzerPrompt</pre>
                }
            }
        </div>
    }
</div>

@if (_confidence is not null && _confidence.Items.Count > 0)
{
    <h2>Rule confidence</h2>
    <p class="muted">Confidence levels from the Phase 8 Recommendation Agent.</p>
    <div class="model-list">
        @foreach (var item in _confidence.Items)
        {
            <div class="card confidence-row">
                <div class="approval-header">
                    <strong>@item.RuleKey</strong>
                    <span class="confidence-pill @GetConfidenceClass(item.Confidence)">@FormatConfidence(item.Confidence)</span>
                    <span class="muted">@item.Trend</span>
                </div>
                <div class="confidence-bar-track">
                    <div class="confidence-bar-fill @GetConfidenceClass(item.Confidence)"
                         style="width: @(Math.Round(item.Confidence * 100))%"></div>
                </div>
            </div>
        }
    </div>
}

@* ── Editor modal ── *@
@if (_editor is not null)
{
    <div class="modal-backdrop" @onclick="CancelEdit"></div>
    <div class="modal" role="dialog" aria-modal="true">
        <div class="modal-head">
            <h2>
                @if (IsSemantic(_editor.ConditionType))
                {
                    <span>🧠 @(_isNew ? "New semantic rule" : $"Edit '{_editorName}'")</span>
                }
                else
                {
                    <span>⚙️ @(_isNew ? "New condition rule" : $"Edit '{_editorName}'")</span>
                }
            </h2>
            <button class="modal-close" @onclick="CancelEdit" title="Close">✕</button>
        </div>
        <EditForm Model="_editor" OnValidSubmit="SaveAsync">
            <div class="modal-body">
                <div class="form-grid">
                    <label class="span-2">
                        Name
                        <InputText @bind-Value="_editor.Name" placeholder="e.g. Simple chat" />
                    </label>

                    @if (IsSemantic(_editor.ConditionType))
                    {
                        <label class="span-2">
                            Rule paragraph
                            <InputTextArea @bind-Value="_editor.Description" rows="5"
                                           placeholder="Describe in plain language what this rule should capture. The local model reads this paragraph to decide whether the user's request matches." />
                            <span class="field-hint">Write it like an instruction to a teammate. Mention example phrases the rule should catch.</span>
                        </label>
                    }
                    else
                    {
                        <label class="span-2">
                            Description
                            <InputText @bind-Value="_editor.Description" placeholder="Short note shown in the rules list" />
                        </label>
                        <label>
                            Condition type
                            <InputSelect @bind-Value="_editor.ConditionType">
                                @foreach (var option in ConditionTypes)
                                {
                                    <option value="@option.Value">@option.Label</option>
                                }
                            </InputSelect>
                        </label>
                        @if (ConditionNeedsValue(_editor.ConditionType))
                        {
                            <label>
                                @ConditionValueLabel(_editor.ConditionType)
                                <InputText @bind-Value="_editor.ConditionValue" />
                            </label>
                        }
                    }

                    <label>
                        @(IsSemantic(_editor.ConditionType) ? "Route to engine" : "Target model")
                        <InputSelect @bind-Value="_editor.TargetModel">
                            <option value="">— select —</option>
                            @foreach (var model in _models)
                            {
                                <option value="@model.Name">@model.Name@(model.IsProcessor ? " (local processor)" : "")</option>
                            }
                        </InputSelect>
                        @if (!string.IsNullOrWhiteSpace(_editor.TargetModel))
                        {
                            var eb = EngineBadge(_editor.TargetModel);
                            <span class="field-hint"><span class="engine-badge @eb.Css">@eb.Icon @eb.Title</span></span>
                        }
                    </label>
                    <label>
                        Order (priority)
                        <InputNumber @bind-Value="_editor.Priority" />
                        <span class="field-hint">Lower numbers are evaluated first.</span>
                    </label>
                    <label class="checkbox">
                        <InputCheckbox @bind-Value="_editor.Enabled" /> Enabled
                    </label>
                </div>
            </div>
            <div class="modal-foot">
                <button type="submit" class="btn-approve">@(_isNew ? "Create rule" : "Save changes")</button>
                <button type="button" class="btn-reject" @onclick="CancelEdit">Cancel</button>
            </div>
        </EditForm>
    </div>
}

@code {
    private List<RoutingRuleDto> _rules = [];
    private List<ModelConnectionDto> _models = [];
    private RulesConfidenceResponse? _confidence;
    private RulesAnalyzerPromptResponse? _analyzerPrompt;
    private bool _loading = true;
    private bool _showAnalyzer;
    private bool _showTestPrompt;
    private bool _testRunning;
    private string? _status;
    private bool _statusOk = true;

    private RuleEditor? _editor;
    private bool _isNew;
    private int _editorId;
    private string _editorName = string.Empty;

    private readonly RuleTestModel _test = new();
    private RuleTestResponse? _testResult;

    private static readonly (string Value, string Label)[] ConditionTypes =
    [
        ("Always", "Always (catch-all)"),
        ("PromptSizeAtLeast", "Prompt size at least (characters)"),
        ("IsStreaming", "Request is streaming"),
        ("HasSystemMessage", "Has a system message"),
        ("RequestedModelEquals", "Requested model equals"),
        ("PromptContainsKeyword", "Prompt contains keyword"),
        ("PromptMatchesRegex", "Prompt matches regex"),
        ("SemanticMatch", "Semantic match")
    ];

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _rules = (await Api.GetRulesAsync()).OrderBy(rule => rule.Priority).ToList();
        _models = (await Api.GetModelsAsync()).ToList();
        _confidence = await Api.GetRulesConfidenceAsync();
        _analyzerPrompt = await Api.GetAnalyzerPromptAsync();
        _loading = false;
    }

    private async Task ToggleEnabledAsync(RoutingRuleDto rule)
    {
        try
        {
            await Api.UpdateRuleAsync(rule.Id, new RoutingRuleUpsertRequest(
                rule.Name, rule.Description, rule.ConditionType, rule.ConditionValue,
                rule.TargetModel, rule.Priority, !rule.Enabled));
            SetStatus($"{(rule.Enabled ? "Disabled" : "Enabled")} rule '{rule.Name}'.", true);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            SetStatus($"Update failed: {ex.Message}", false);
        }
    }

    private void StartCreate()
    {
        _isNew = true;
        _editorId = 0;
        _editorName = string.Empty;
        _editor = new RuleEditor
        {
            ConditionType = "PromptSizeAtLeast",
            ConditionValue = "8000",
            Priority = (_rules.Count + 1) * 10,
            Enabled = true,
            TargetModel = _models.FirstOrDefault()?.Name ?? string.Empty
        };
    }

    private void StartCreateSemantic()
    {
        _isNew = true;
        _editorId = 0;
        _editorName = string.Empty;
        _editor = new RuleEditor
        {
            ConditionType = "SemanticMatch",
            ConditionValue = string.Empty,
            Priority = (_rules.Count + 1) * 10,
            Enabled = true,
            TargetModel = SelectProcessorModel()?.Name ?? _models.FirstOrDefault()?.Name ?? string.Empty
        };
    }

    private void StartEdit(RoutingRuleDto rule)
    {
        _isNew = false;
        _editorId = rule.Id;
        _editorName = rule.Name;
        _editor = new RuleEditor
        {
            Name = rule.Name,
            Description = rule.Description,
            ConditionType = rule.ConditionType,
            ConditionValue = rule.ConditionValue,
            TargetModel = rule.TargetModel,
            Priority = rule.Priority,
            Enabled = rule.Enabled
        };
    }

    private void CancelEdit() => _editor = null;

    private async Task SaveAsync()
    {
        if (_editor is null)
        {
            return;
        }

        try
        {
            var request = new RoutingRuleUpsertRequest(
                _editor.Name,
                _editor.Description ?? string.Empty,
                _editor.ConditionType,
                ConditionNeedsValue(_editor.ConditionType) ? _editor.ConditionValue ?? string.Empty : string.Empty,
                _editor.TargetModel,
                _editor.Priority,
                _editor.Enabled);

            if (_isNew)
            {
                await Api.CreateRuleAsync(request);
                SetStatus($"Created rule '{_editor.Name}'.", true);
            }
            else
            {
                await Api.UpdateRuleAsync(_editorId, request);
                SetStatus($"Saved rule '{_editor.Name}'.", true);
            }

            _editor = null;
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            SetStatus($"Save failed: {ex.Message}", false);
        }
    }

    private async Task DeleteAsync(RoutingRuleDto rule)
    {
        try
        {
            await Api.DeleteRuleAsync(rule.Id);
            SetStatus($"Deleted rule '{rule.Name}'.", true);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            SetStatus($"Delete failed: {ex.Message}", false);
        }
    }

    private async Task GenerateStarterRulesAsync()
    {
        if (_rules.Count > 0)
        {
            return;
        }

        var localModel = SelectProcessorModel() ?? _models.FirstOrDefault();
        var cloudModel = SelectCloudModel() ?? _models.FirstOrDefault();

        if (localModel is null || cloudModel is null)
        {
            SetStatus("Starter rules require at least one registered model.", false);
            return;
        }

        try
        {
            await Api.CreateRuleAsync(new RoutingRuleUpsertRequest(
                "Simple chat",
                "Captures short, simple, conversational prompts in any language - greetings and small talk such as 'hi', 'hello', 'hola', 'thanks', 'gracias', 'how are you' - that do not require reading or changing code. Also captures lightweight information lookups that GitHub Copilot answers using its web search tools, for example 'search the web for ...', 'look up ...', 'find online ...', 'what is the latest ...', or general questions about current facts or documentation.",
                "SemanticMatch",
                string.Empty,
                localModel.Name,
                5,
                true));

            await Api.CreateRuleAsync(new RoutingRuleUpsertRequest(
                "GitHub actions",
                "Captures all GitHub related actions, for example: commit all the changes, push to GitHub, create a pull request.",
                "SemanticMatch",
                string.Empty,
                localModel.Name,
                10,
                true));

            await Api.CreateRuleAsync(new RoutingRuleUpsertRequest(
                "Launch App actions",
                "Captures all actions where the user asks Copilot to launch, run, build or start the application.",
                "SemanticMatch",
                string.Empty,
                localModel.Name,
                20,
                true));

            await Api.CreateRuleAsync(new RoutingRuleUpsertRequest(
                "Others actions",
                "Catch-all rule. Captures every request that does not match the other rules, including complex coding tasks.",
                "SemanticMatch",
                string.Empty,
                cloudModel.Name,
                30,
                true));

            SetStatus("Starter semantic rules generated.", true);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            SetStatus($"Starter rules failed: {ex.Message}", false);
        }
    }

    private async Task RunTestAsync()
    {
        _testRunning = true;
        _showTestPrompt = false;
        try
        {
            _testResult = await Api.TestRuleAsync(new RuleTestRequest(
                _test.Prompt ?? string.Empty,
                string.IsNullOrWhiteSpace(_test.SystemMessage) ? null : _test.SystemMessage,
                _test.Stream,
                string.IsNullOrWhiteSpace(_test.RequestedModel) ? null : _test.RequestedModel));
        }
        finally
        {
            _testRunning = false;
        }
    }

    private (string Icon, string Title, string Css) EngineBadge(string? modelName)
    {
        var model = _models.FirstOrDefault(m => string.Equals(m.Name, modelName, StringComparison.OrdinalIgnoreCase));
        if (model is null)
        {
            return ("❓", "unknown engine", "engine-unknown");
        }

        var isLocal = string.Equals(model.Type, "ollama", StringComparison.OrdinalIgnoreCase);
        var title = model.IsProcessor ? (isLocal ? "local · processor" : "cloud · processor")
                                      : (isLocal ? "local" : "cloud");
        return isLocal ? ("🖥️", title, "engine-local") : ("☁️", title, "engine-cloud");
    }

    private static string DescribeSource(string source) =>
        source switch
        {
            "processor-model" => "local model (LLM)",
            "deterministic" => "keyword fallback",
            "" => "default",
            _ => source
        };

    private void SetStatus(string message, bool ok)
    {
        _status = message;
        _statusOk = ok;
    }

    private static bool ConditionNeedsValue(string conditionType) =>
        conditionType is "PromptSizeAtLeast" or "RequestedModelEquals" or "PromptContainsKeyword" or "PromptMatchesRegex";

    private static bool IsSemantic(string conditionType) => conditionType == "SemanticMatch";

    private ModelConnectionDto? SelectProcessorModel() =>
        _models.FirstOrDefault(model => model.IsProcessor);

    private ModelConnectionDto? SelectCloudModel() =>
        _models.FirstOrDefault(model => !model.IsProcessor);

    private static string ConditionValueLabel(string conditionType) =>
        conditionType switch
        {
            "PromptSizeAtLeast" => "Minimum characters",
            "RequestedModelEquals" => "Model name",
            "PromptContainsKeyword" => "Keyword",
            "PromptMatchesRegex" => "Regular expression",
            _ => "Value"
        };

    private static string DescribeCondition(RoutingRuleDto rule) =>
        rule.ConditionType switch
        {
            "Always" => "Always",
            "IsStreaming" => "Streaming request",
            "HasSystemMessage" => "Has system message",
            "PromptSizeAtLeast" => $"Prompt ≥ {rule.ConditionValue} chars",
            "RequestedModelEquals" => $"Requested model = '{rule.ConditionValue}'",
            "PromptContainsKeyword" => $"Contains '{rule.ConditionValue}'",
            "PromptMatchesRegex" => $"Matches /{rule.ConditionValue}/",
            "SemanticMatch" => "Semantic match",
            _ => rule.ConditionType
        };

    private static string GetConfidenceClass(double confidence) =>
        confidence switch
        {
            >= 0.8 => "confidence-high",
            >= 0.5 => "confidence-medium",
            _ => "confidence-low"
        };

    private static string FormatConfidence(double confidence) => $"{Math.Round(confidence * 100)}%";

    private sealed class RuleEditor
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string ConditionType { get; set; } = "Always";
        public string? ConditionValue { get; set; }
        public string TargetModel { get; set; } = string.Empty;
        public int Priority { get; set; }
        public bool Enabled { get; set; } = true;
    }

    private sealed class RuleTestModel
    {
        public string? Prompt { get; set; }
        public string? SystemMessage { get; set; }
        public string? RequestedModel { get; set; }
        public bool Stream { get; set; }
    }
}
