@page "/live"
@using ElBruno.CopilotHarness.Admin.Web.Services
@inject AdminApiClient Api
@implements IAsyncDisposable

<PageTitle>Live Routing</PageTitle>

<div class="page-header">
    <div>
        <h1>Live Routing</h1>
        <p class="muted">Watch the harness pipeline in real time: each prompt is read by the <strong>processor model</strong>,
           classified into an <strong>intent</strong>, matched to a <strong>rule</strong>, and routed to a <strong>target model</strong>.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <p class="error">@_error</p>
}

@if (_feed is null)
{
    <p>Loading routing feed…</p>
}
else
{
    @if (!_feed.PromptCaptureEnabled)
    {
        <article class="card notice">
            <strong>Prompt text capture is disabled.</strong>
            <p>
                Models, intents, rules, and explanations are shown below. To also display a redacted preview
                of each prompt, set <code>Telemetry__CapturePromptText=true</code> on the router
                (already enabled by default in the local Aspire AppHost).
            </p>
        </article>
    }

    @if (_feed.Requests.Count > 0)
    {
        <p class="summary-caption muted" title="These badges group requests by the classifier's secondary intent guess — not by the rule that was actually chosen.">
            By classifier intent (heuristic) · the matched <strong>rule</strong> below is what actually routes each request.
        </p>
        <div class="summary-cards">
            @foreach (var group in _feed.Requests.GroupBy(r => string.IsNullOrWhiteSpace(r.ClassificationIntent) ? "unknown" : r.ClassificationIntent).OrderByDescending(g => g.Count()))
            {
                <article class="summary-card">
                    <span class="intent-badge intent-@group.Key">intent: @group.Key</span>
                    <p>@group.Count() request(s) · @((100.0 * group.Count() / _feed.Requests.Count).ToString("0")) %</p>
                </article>
            }
            <article class="summary-card">
                <span class="muted">Decision source</span>
                <p>
                    🧠 @_feed.Requests.Count(r => r.ClassifierSource == "processor-model") local model ·
                    ⚙️ @_feed.Requests.Count(r => r.ClassifierSource != "processor-model") heuristic
                </p>
            </article>
        </div>
    }

    <div class="recent-head">
        <h2>Recent requests (@_filteredCount@(_filteredCount != _feed.Requests.Count ? $" of {_feed.Requests.Count}" : ""))</h2>
        <div class="recent-actions">
            @if (_selected.Count > 0)
            {
                <button class="btn-reject" @onclick="BeginBulkDelete">🗑 Delete selected (@_selected.Count)</button>
            }
            @if (_feed.Requests.Count > 0)
            {
                <button class="btn-reject" @onclick="BeginClearAll">Clear all</button>
            }
        </div>
    </div>

    @if (_feed.Requests.Count > 0)
    {
        <div class="filter-bar">
            <input class="filter-text" type="search" placeholder="Filter by prompt, model or rule…"
                   value="@_filterText" @oninput="OnFilterInput" />
            <select value="@_modelFilter" @onchange="OnModelFilterChanged">
                <option value="">All models</option>
                @foreach (var model in DistinctModels())
                {
                    <option value="@model">@model</option>
                }
            </select>
            <select value="@_ruleFilter" @onchange="OnRuleFilterChanged">
                <option value="">All rules</option>
                @foreach (var rule in DistinctRules())
                {
                    <option value="@rule">@rule</option>
                }
            </select>
            @if (HasActiveFilter)
            {
                <button class="btn-ghost" @onclick="ClearFilters">Clear filters</button>
            }
        </div>
    }

    @if (_confirmClearAll)
    {
        <div class="confirm-banner">
            <span><strong>Delete all @_feed.Requests.Count request(s)?</strong> This cannot be undone.</span>
            <span class="confirm-actions">
                <button class="btn-reject" @onclick="ConfirmClearAll">Yes, clear all</button>
                <button class="btn-ghost" @onclick="() => _confirmClearAll = false">Cancel</button>
            </span>
        </div>
    }

    @if (_confirmBulkDelete)
    {
        <div class="confirm-banner">
            <span><strong>Delete @_selected.Count selected request(s)?</strong> This cannot be undone.</span>
            <span class="confirm-actions">
                <button class="btn-reject" @onclick="ConfirmBulkDelete">Yes, delete selected</button>
                <button class="btn-ghost" @onclick="() => _confirmBulkDelete = false">Cancel</button>
            </span>
        </div>
    }

    @if (_feed.Requests.Count == 0)
    {
        <div class="empty-state">
            <p class="empty-title">No routed requests yet</p>
            <p class="muted">Send a prompt from VS Code Copilot (BYOK) to see it flow through the pipeline here.</p>
        </div>
    }
    else if (_filteredCount == 0)
    {
        <div class="empty-state">
            <p class="empty-title">No requests match your filters</p>
            <button class="btn-ghost" @onclick="ClearFilters">Clear filters</button>
        </div>
    }
    else
    {
        <div class="pipeline-list">
            @foreach (var request in _pageItems)
            {
                <article class="pipeline-row @(_selected.Contains(request.TraceId) ? "row-selected" : "")">
                    <div class="pipeline-topbar">
                        <label class="select-box" title="Select for bulk delete">
                            <input type="checkbox" checked="@_selected.Contains(request.TraceId)"
                                   @onchange="e => ToggleSelect(request.TraceId, e.Value is bool b && b)" />
                        </label>
                        <div class="pipeline-time" title="@request.CreatedAtUtc.ToLocalTime().ToString("u")">
                            @request.CreatedAtUtc.ToLocalTime().ToString("HH:mm:ss")
                        </div>
                        <div class="row-actions">
                            @if (_confirmDeleteId == request.TraceId)
                            {
                                <span class="muted">Delete?</span>
                                <button class="btn-reject btn-sm" @onclick="() => ConfirmDeleteRow(request.TraceId)">Yes</button>
                                <button class="btn-ghost btn-sm" @onclick="() => _confirmDeleteId = null">No</button>
                            }
                            else
                            {
                                <button class="icon-btn" title="Delete this request" @onclick="() => _confirmDeleteId = request.TraceId">🗑</button>
                            }
                        </div>
                    </div>
                    <div class="pipeline-flow">
                        <div class="stage stage-prompt">
                            <span class="stage-label">User message</span>
                            <span class="stage-value" title="@request.PromptPreview">
                                @(string.IsNullOrWhiteSpace(request.PromptPreview)
                                    ? $"({request.PromptCharacters} chars)"
                                    : Truncate(request.PromptPreview!, 80))
                            </span>
                            <span class="stage-sub">@request.ClientDisplayName</span>
                            @if (request.HasSystemMessage || request.TotalPromptCharacters > request.PromptCharacters)
                            {
                                <span class="stage-context" title="Routing uses your message only. Copilot also sends a large system preamble + prior turns, which the harness ignores for routing.">
                                    📎 @request.PromptCharacters of @request.TotalPromptCharacters ctx chars
                                    @if (request.HasSystemMessage)
                                    {
                                        <text> · system preamble</text>
                                    }
                                </span>
                            }
                        </div>
                        <span class="arrow">→</span>
                        <div class="stage stage-processor">
                            <span class="stage-label" title="How the rule below was chosen">
                                @(request.ClassifierSource == "processor-model" ? "🧠 Decided by local model" : "⚙️ Keyword/heuristic fallback")
                            </span>
                            <span class="stage-sub">
                                @(string.IsNullOrWhiteSpace(request.ProcessorModel) ? request.ClassificationComplexity : request.ProcessorModel)
                                · @request.ClassificationConfidence.ToString("0.00")
                            </span>
                            @if (!string.IsNullOrWhiteSpace(request.ClassificationIntent))
                            {
                                <span class="intent-hint" title="Secondary heuristic guess about the request — NOT the rule that was chosen.">
                                    @(request.ClassifierSource == "processor-model" ? "intent (guess): " : "intent: ")@request.ClassificationIntent
                                </span>
                            }
                        </div>
                        <span class="arrow">→</span>
                        <div class="stage stage-rule stage-primary">
                            <span class="stage-label">Matched rule</span>
                            <span class="stage-value"><strong>@(request.MatchedRuleName ?? "—")</strong></span>
                        </div>
                        <span class="arrow">→</span>
                        <div class="stage stage-model">
                            <span class="stage-label">Model</span>
                            <span class="stage-value"><strong>@request.SelectedModel</strong></span>
                            <span class="stage-sub">@request.Deployment</span>
                        </div>
                    </div>
                    <div class="pipeline-why">
                        <span class="muted"><strong>Why this rule:</strong> @RuleSelectionReason(request)</span>
                        <span class="trace muted">@request.TraceId</span>
                    </div>
                    <details class="payload-details">
                        <summary>User message — @PromptSummary(request)</summary>
                        <div class="payload-text">@DisplayPrompt(request)</div>
                    </details>
                    @if (!string.IsNullOrWhiteSpace(request.RawUserMessage))
                    {
                        <details class="payload-details">
                            <summary>Raw Copilot payload</summary>
                            <div class="payload-text payload-raw">@request.RawUserMessage</div>
                        </details>
                    }
                </article>
            }
        </div>

        @if (_totalPages > 1)
        {
            <div class="pager">
                <button class="btn-ghost" disabled="@(_page == 0)" @onclick="PrevPage">← Prev</button>
                <span class="pager-info">Page @(_page + 1) of @_totalPages</span>
                <button class="btn-ghost" disabled="@(_page >= _totalPages - 1)" @onclick="NextPage">Next →</button>
            </div>
        }
    }

    <p class="muted">Snapshot: @_feed.GeneratedAtUtc.ToLocalTime().ToString("u")</p>
}

@code {
    private const int PageSize = 20;

    private readonly CancellationTokenSource _loopCancellation = new();
    private Task? _loopTask;
    private RoutingFeedResponse? _feed;
    private string? _error;

    private string _filterText = string.Empty;
    private string _modelFilter = string.Empty;
    private string _ruleFilter = string.Empty;
    private int _page;

    private readonly HashSet<string> _selected = new(StringComparer.OrdinalIgnoreCase);
    private string? _confirmDeleteId;
    private bool _confirmBulkDelete;
    private bool _confirmClearAll;

    private List<RoutedRequestView> _pageItems = new();
    private int _totalPages = 1;
    private int _filteredCount;

    private void Recompute()
    {
        var filtered = FilteredRequests().ToList();
        _filteredCount = filtered.Count;
        _totalPages = Math.Max(1, (filtered.Count + PageSize - 1) / PageSize);
        if (_page >= _totalPages) { _page = _totalPages - 1; }
        if (_page < 0) { _page = 0; }
        _pageItems = filtered.Skip(_page * PageSize).Take(PageSize).ToList();
    }

    private void PrevPage()
    {
        if (_page > 0) { _page--; }
        Recompute();
    }

    private void NextPage()
    {
        if (_page < _totalPages - 1) { _page++; }
        Recompute();
    }

    private bool HasActiveFilter =>
        !string.IsNullOrWhiteSpace(_filterText) ||
        !string.IsNullOrWhiteSpace(_modelFilter) ||
        !string.IsNullOrWhiteSpace(_ruleFilter);

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        _loopTask = RunLoopAsync(_loopCancellation.Token);
    }

    private async Task RunLoopAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        while (await timer.WaitForNextTickAsync(cancellationToken))
        {
            await RefreshAsync(cancellationToken);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshAsync(CancellationToken cancellationToken = default)
    {
        try
        {
            _feed = await Api.GetRoutingFeedAsync(200, cancellationToken);
            _error = null;
            // Prune selection / pending confirm for traces that no longer exist.
            var present = _feed.Requests.Select(r => r.TraceId).ToHashSet(StringComparer.OrdinalIgnoreCase);
            _selected.RemoveWhere(id => !present.Contains(id));
            if (_confirmDeleteId is not null && !present.Contains(_confirmDeleteId))
            {
                _confirmDeleteId = null;
            }
            Recompute();
        }
        catch (Exception exception)
        {
            _error = $"Could not refresh routing feed: {exception.Message}";
        }
    }

    private IEnumerable<RoutedRequestView> FilteredRequests()
    {
        IEnumerable<RoutedRequestView> items = _feed?.Requests ?? Enumerable.Empty<RoutedRequestView>();

        if (!string.IsNullOrWhiteSpace(_modelFilter))
        {
            items = items.Where(r => string.Equals(r.SelectedModel, _modelFilter, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(_ruleFilter))
        {
            items = items.Where(r => string.Equals(r.MatchedRuleName ?? string.Empty, _ruleFilter, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(_filterText))
        {
            var term = _filterText.Trim();
            items = items.Where(r =>
                Contains(r.PromptPreview, term) ||
                Contains(r.RawUserMessage, term) ||
                Contains(r.SelectedModel, term) ||
                Contains(r.MatchedRuleName, term) ||
                Contains(r.ClassificationIntent, term));
        }

        return items;
    }

    private static bool Contains(string? value, string term) =>
        !string.IsNullOrEmpty(value) && value.Contains(term, StringComparison.OrdinalIgnoreCase);

    private IEnumerable<string> DistinctModels() =>
        (_feed?.Requests ?? Enumerable.Empty<RoutedRequestView>())
            .Select(r => r.SelectedModel)
            .Where(m => !string.IsNullOrWhiteSpace(m))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(m => m, StringComparer.OrdinalIgnoreCase);

    private IEnumerable<string> DistinctRules() =>
        (_feed?.Requests ?? Enumerable.Empty<RoutedRequestView>())
            .Select(r => r.MatchedRuleName)
            .Where(m => !string.IsNullOrWhiteSpace(m))
            .Select(m => m!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(m => m, StringComparer.OrdinalIgnoreCase);

    private void OnFilterInput(ChangeEventArgs e)
    {
        _filterText = e.Value?.ToString() ?? string.Empty;
        _page = 0;
        Recompute();
    }

    private void OnModelFilterChanged(ChangeEventArgs e)
    {
        _modelFilter = e.Value?.ToString() ?? string.Empty;
        _page = 0;
        Recompute();
    }

    private void OnRuleFilterChanged(ChangeEventArgs e)
    {
        _ruleFilter = e.Value?.ToString() ?? string.Empty;
        _page = 0;
        Recompute();
    }

    private void ClearFilters()
    {
        _filterText = string.Empty;
        _modelFilter = string.Empty;
        _ruleFilter = string.Empty;
        _page = 0;
        Recompute();
    }

    private void ToggleSelect(string traceId, bool selected)
    {
        if (selected)
        {
            _selected.Add(traceId);
        }
        else
        {
            _selected.Remove(traceId);
        }
    }

    private async Task ConfirmDeleteRow(string traceId)
    {
        try
        {
            await Api.DeleteTraceAsync(traceId);
            _selected.Remove(traceId);
            _confirmDeleteId = null;
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _error = $"Delete failed: {ex.Message}";
        }
    }

    private void BeginBulkDelete()
    {
        _confirmClearAll = false;
        _confirmBulkDelete = true;
    }

    private async Task ConfirmBulkDelete()
    {
        try
        {
            await Api.DeleteTracesAsync(_selected.ToList());
            _selected.Clear();
            _confirmBulkDelete = false;
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _error = $"Bulk delete failed: {ex.Message}";
        }
    }

    private void BeginClearAll()
    {
        _confirmBulkDelete = false;
        _confirmClearAll = true;
    }

    private async Task ConfirmClearAll()
    {
        try
        {
            await Api.ClearTracesAsync();
            _selected.Clear();
            _confirmClearAll = false;
            _page = 0;
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _error = $"Clear all failed: {ex.Message}";
        }
    }

    private static string Truncate(string value, int max) =>
        value.Length <= max ? value : value[..max] + "…";

    private static string DisplayPrompt(RoutedRequestView request) =>
        string.IsNullOrWhiteSpace(request.PromptPreview)
            ? $"({request.PromptCharacters} chars captured)"
            : request.PromptPreview!;

    private static string PromptSummary(RoutedRequestView request) =>
        Truncate(DisplayPrompt(request).ReplaceLineEndings(" "), 80);

    private static string RuleSelectionReason(RoutedRequestView request) =>
        !string.IsNullOrWhiteSpace(request.SemanticReason)
            ? request.SemanticReason!
            : request.Explanation;

    public async ValueTask DisposeAsync()
    {
        _loopCancellation.Cancel();
        if (_loopTask is not null)
        {
            try
            {
                await _loopTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        _loopCancellation.Dispose();
    }
}
